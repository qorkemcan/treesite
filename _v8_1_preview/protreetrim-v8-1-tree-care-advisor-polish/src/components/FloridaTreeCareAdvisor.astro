---
import advisorData from "../data/florida-tree-care-advisor.json";
import { SITE_CONFIG } from "../config.js";
---

<section class="advisor-card" data-tree-care-advisor>
  <div class="advisor-grid">
    <form class="advisor-form" id="treeCareAdvisorForm">
      <div class="field-group">
        <label for="region">Florida area</label>
        <select id="region" name="region" required>
          <option value="central-florida">Central Florida</option>
          <option value="north-florida">North Florida</option>
          <option value="south-florida">South Florida</option>
          <option value="coastal-florida">Coastal Florida</option>
          <option value="rural-acreage">Rural lots & acreage</option>
          <option value="hoa-suburban">HOA / suburban neighborhood</option>
        </select>
      </div>

      <div class="field-group">
        <label for="concern">Main concern</label>
        <select id="concern" name="concern" required>
          <option value="storm-risk">Storm risk or leaning tree</option>
          <option value="palm-care">Palm care or browning fronds</option>
          <option value="stump-after-removal">Stump, roots, or replanting after removal</option>
          <option value="roots-hardscape">Roots near driveway, pool, sidewalk, or foundation</option>
          <option value="permit-question">Permit, HOA, or protected tree question</option>
        </select>
      </div>

      <div class="field-group">
        <label for="season">Timing</label>
        <select id="season" name="season" required>
          <option value="hurricane-season">Hurricane season / storm prep</option>
          <option value="summer">Summer / rainy season</option>
          <option value="spring">Spring / early growing season</option>
          <option value="fall-winter">Fall / winter</option>
        </select>
      </div>

      <button type="submit">Get Florida Tree Care Guidance</button>
      <div class="advisor-prep-list" aria-label="Information to prepare before calling">
        <strong>Before calling, note:</strong>
        <ul>
          <li>Where the tree is located</li>
          <li>Nearby roof, fence, pool, driveway, or wires</li>
          <li>Recent storm damage or sudden leaning</li>
          <li>Photos taken from a safe distance</li>
        </ul>
      </div>

      <p class="form-note">This tool offers general homeowner guidance, not a diagnosis or legal permit determination.</p>
    </form>

    <div class="advisor-result" id="advisorResult" aria-live="polite">
      <div class="result-kicker">Florida Tree Care Advisor</div>
      <h2>Choose your area and concern to get practical next steps.</h2>
      <p>Use this tool before calling a crew, comparing estimates, or deciding whether a tree issue can wait.</p>
    </div>
  </div>
</section>

<script is:inline define:vars={{ advisorData, phoneHref: SITE_CONFIG.phoneHref }}>
  const form = document.getElementById("treeCareAdvisorForm");
  const result = document.getElementById("advisorResult");

  const escapeHtml = (value = "") => String(value)
    .replace(/&/g, "&amp;")
    .replace(/</g, "&lt;")
    .replace(/>/g, "&gt;")
    .replace(/"/g, "&quot;")
    .replace(/'/g, "&#039;");

  const renderList = (items = []) => items.map((item) => `<li>${escapeHtml(item)}</li>`).join("");
  const renderLinks = (items = []) => items.map((item) => (
    `<a class="guide-link" href="${escapeHtml(item.href)}">
      <span>${escapeHtml(item.title)}</span>
      <strong>Read guide →</strong>
    </a>`
  )).join("");

  function renderAdvice() {
    const region = advisorData.regions[form.region.value];
    const concern = advisorData.concerns[form.concern.value];
    const season = advisorData.seasons[form.season.value];

    if (!region || !concern || !season) return;

    result.innerHTML = `
      <div class="result-kicker">${escapeHtml(region.label)} • ${escapeHtml(season.label)}</div>
      <h2>${escapeHtml(concern.risk)} attention recommended</h2>
      <p class="result-summary">${escapeHtml(region.summary)}</p>

      <div class="result-profile-grid">
        <div>
          <span>Area profile</span>
          <strong>${escapeHtml(region.zone)}</strong>
        </div>
        <div>
          <span>Primary concern</span>
          <strong>${escapeHtml(concern.label)}</strong>
        </div>
      </div>

      <div class="result-section">
        <h3>What matters in this area</h3>
        <ul>${renderList(region.commonRisks)}</ul>
      </div>

      <div class="result-section highlight-section">
        <h3>Current guidance</h3>
        <p>${escapeHtml(concern.note)}</p>
        <p>${escapeHtml(season.note)}</p>
      </div>

      <div class="result-section">
        <h3>Suggested next steps</h3>
        <ul>${renderList([...region.baselineActions.slice(0, 2), ...concern.actions])}</ul>
      </div>

      <div class="result-section">
        <h3>Related ProTreeTrim guides</h3>
        <div class="guide-links">${renderLinks(region.relatedGuides)}</div>
      </div>

      <div class="advisor-cta-row">
        <a class="advisor-primary-cta" href="${phoneHref}">Call Dispatch</a>
        <a class="advisor-secondary-cta" href="${escapeHtml(concern.serviceLink.href)}">${escapeHtml(concern.serviceLink.title)}</a>
      </div>
    `;
  }

  form?.addEventListener("submit", (event) => {
    event.preventDefault();
    renderAdvice();
  });

  renderAdvice();
</script>

<style>
  .advisor-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: 30px;
    box-shadow: 0 18px 50px rgba(15, 23, 42, 0.08);
    overflow: hidden;
    margin-bottom: 2rem;
  }

  .advisor-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.9fr) minmax(320px, 1.4fr);
    gap: 0;
  }

  .advisor-form {
    background: linear-gradient(180deg, #0f2f24 0%, #0b2a20 100%);
    color: white;
    padding: clamp(1.5rem, 4vw, 2.5rem);
  }

  .field-group {
    margin-bottom: 1.2rem;
  }

  .field-group label {
    display: block;
    font-size: 0.78rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #bbf7d0;
    margin-bottom: 0.5rem;
  }

  .field-group select {
    width: 100%;
    padding: 0.95rem 1rem;
    border-radius: 12px;
    border: 1px solid rgba(255, 255, 255, 0.22);
    background: rgba(255, 255, 255, 0.08);
    color: white;
    font-weight: 800;
    font-size: 0.98rem;
  }

  .field-group option {
    color: #0f172a;
  }

  .advisor-form button {
    width: 100%;
    border: 0;
    border-radius: 14px;
    background: #ea580c;
    color: white;
    padding: 1rem 1.2rem;
    font-weight: 900;
    font-size: 1rem;
    cursor: pointer;
    box-shadow: 0 12px 24px rgba(234, 88, 12, 0.28);
  }

  .advisor-prep-list {
    margin-top: 1.35rem;
    padding: 1rem;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.14);
    color: rgba(255, 255, 255, 0.84);
  }

  .advisor-prep-list strong {
    display: block;
    color: #bbf7d0;
    font-size: 0.82rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 900;
    margin-bottom: 0.55rem;
  }

  .advisor-prep-list ul {
    margin: 0;
    padding-left: 1.1rem;
    line-height: 1.55;
    font-size: 0.88rem;
  }

  .form-note {
    color: rgba(255, 255, 255, 0.72);
    font-size: 0.82rem;
    line-height: 1.55;
    margin: 1rem 0 0;
  }

  .advisor-result {
    padding: clamp(1.5rem, 4vw, 2.75rem);
    padding-bottom: clamp(2.5rem, 5vw, 4rem);
    color: #163524;
  }

  .advisor-result h2 {
    color: #123d2b;
    font-size: clamp(1.65rem, 4vw, 2.55rem);
    line-height: 1.05;
    margin: 0 0 1rem;
    font-weight: 900;
  }

  .advisor-result p {
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  .advisor-card :global(.result-kicker) {
    color: #ea580c;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-size: 0.76rem;
    font-weight: 900;
    margin-bottom: 0.65rem;
  }

  .advisor-card :global(.result-summary) {
    color: #475569;
    font-size: 1rem;
    line-height: 1.7;
  }

  .advisor-card :global(.result-profile-grid) {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 0.8rem;
    margin: 1.3rem 0;
  }

  .advisor-card :global(.result-profile-grid div) {
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: 16px;
    padding: 0.85rem 0.95rem;
  }

  .advisor-card :global(.result-profile-grid span) {
    display: block;
    color: #166534;
    font-size: 0.72rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 900;
    margin-bottom: 0.3rem;
  }

  .advisor-card :global(.result-profile-grid strong) {
    display: block;
    color: #123d2b;
    font-size: 0.95rem;
    line-height: 1.35;
  }

  .advisor-card :global(.result-section) {
    border-top: 1px solid #e5e7eb;
    padding-top: 1.1rem;
    margin-top: 1.1rem;
  }

  .advisor-card :global(.result-section h3) {
    color: #123d2b;
    margin: 0 0 0.7rem;
    font-size: 1.05rem;
    font-weight: 900;
  }

  .advisor-card :global(.result-section ul) {
    margin: 0;
    padding-left: 1.2rem;
    color: #475569;
    line-height: 1.7;
  }

  .advisor-card :global(.highlight-section) {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 18px;
    padding: 1.15rem;
  }

  .advisor-card :global(.guide-links) {
    display: grid;
    gap: 0.7rem;
  }

  .advisor-card :global(.guide-link) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    color: #123d2b;
    text-decoration: none;
    font-weight: 850;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: 14px;
    padding: 0.85rem 0.95rem;
    transition: transform 0.15s ease, border-color 0.15s ease, background 0.15s ease;
  }

  .advisor-card :global(.guide-link:hover) {
    transform: translateY(-1px);
    border-color: #bbf7d0;
    background: #f0fdf4;
  }

  .advisor-card :global(.guide-link strong) {
    color: #166534;
    white-space: nowrap;
    font-size: 0.86rem;
  }

  .advisor-card :global(.advisor-cta-row) {
    display: flex;
    flex-wrap: wrap;
    gap: 0.85rem;
    margin-top: 1.5rem;
  }

  .advisor-card :global(.advisor-primary-cta),
  .advisor-card :global(.advisor-secondary-cta) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 12px;
    padding: 0.95rem 1.2rem;
    font-weight: 900;
    text-decoration: none;
  }

  .advisor-card :global(.advisor-primary-cta) {
    background: #ea580c;
    color: white;
  }

  .advisor-card :global(.advisor-secondary-cta) {
    background: #ecfdf5;
    color: #166534;
    border: 1px solid #bbf7d0;
  }

  @media (max-width: 860px) {
    .advisor-grid {
      grid-template-columns: 1fr;
    }

    .advisor-card :global(.result-profile-grid) {
      grid-template-columns: 1fr;
    }

    .advisor-card :global(.guide-link) {
      align-items: flex-start;
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>