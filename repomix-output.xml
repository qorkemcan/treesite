      "tree health & disease": "Tree Health & Disease",
      "landscaping & planting": "Landscaping & Planting",
      "local florida guides": "Local Florida Guides",
      "tree removal": "Tree Removal",
    };

    return aliases[clean.toLowerCase()] ?? clean;
  };

  const localSlugifyCategory = (value: string) =>
    localNormalizeCategory(value)
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9\s-]/g, "")
      .replace(/\s+/g, "-");

  const posts = await getCollection("blog", ({ data }) => !data.draft);

  const categories = [
    ...new Set(
      posts
        .map((post) => localNormalizeCategory(post.data.category))
        .filter(Boolean),
    ),
  ] as string[];

  return categories.map((category) => {
    const categoryPosts = posts
      .filter((post) => localNormalizeCategory(post.data.category) === category)
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    return {
      params: {
        slug: localSlugifyCategory(category),
      },
      props: {
        categoryName: category,
        posts: categoryPosts.slice(0, POSTS_PER_PAGE),
        totalPosts: categoryPosts.length,
        totalPages: Math.ceil(categoryPosts.length / POSTS_PER_PAGE),
        currentPage: 1,
      },
    };
  });
}

const { categoryName, posts, totalPosts, totalPages, currentPage } =
  Astro.props;

const categorySlug = slugifyCategory(categoryName);

const pageTitle = `${categoryName} Articles | ProTreeTrim Blog`;
const pageDescription = `Read ${categoryName.toLowerCase()} articles from the ProTreeTrim blog.`;
const canonicalUrl = `${SITE_CONFIG.siteUrl}/blog/category/${categorySlug}/`;

const startPost = totalPosts === 0 ? 0 : 1;
const endPost = Math.min(posts.length, totalPosts);
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="canonical" href={canonicalUrl} />
    {
      totalPages > 1 && (
        <link
          rel="next"
          href={`${SITE_CONFIG.siteUrl}/blog/category/${categorySlug}/page/2/`}
        />
      )
    }
  </Fragment>

  <header
    style="background: linear-gradient(135deg, #1b4332 0%, #081c15 100%); color: white; padding: 4.5rem 1.5rem; text-align: center; border-bottom: 5px solid #ea580c;"
  >
    <div class="container">
      <div
        style="font-size: 0.85rem; margin-bottom: 1rem; color: #ffb703; font-weight: 800; text-transform: uppercase;"
      >
        Blog Category Archive
      </div>
      <h1
        style="font-size: clamp(2.2rem, 6vw, 3.6rem); margin: 0; font-weight: 900;"
      >
        {categoryName}
      </h1>
      <p
        style="font-size: 1.05rem; color: #95d5b2; margin-top: 1rem; max-width: 760px; margin-left: auto; margin-right: auto;"
      >
        Browse all posts filed under {categoryName}.
      </p>
    </div>
  </header>

  <main
    class="container"
    style="padding: 3rem 1.5rem 10rem; max-width: 1100px;"
  >
    <div style="margin-bottom: 1.75rem;">
      <a
        href="/blog/"
        style="display: inline-block; color: #166534; text-decoration: none; font-weight: 800;"
      >
        ← Back to all blog posts
      </a>
    </div>

    <div
      style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
    >
      <strong style="color: #1b4332;">{startPost}-{endPost}</strong>
      <span style="color: #64748b;">
        of {totalPosts} article(s) in this category</span
      >
    </div>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;"
    >
      {
        posts.map((post) => (
          <article style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.75rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;">
              <span style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">
                {normalizeCategory(post.data.category)}
              </span>
              <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </div>

            <h2 style="margin: 0 0 0.75rem; font-size: 1.55rem; line-height: 1.2;">
              <a
                href={`/blog/${post.slug}/`}
                style="color: #1b4332; text-decoration: none; font-weight: 900;"
              >
                {post.data.title}
              </a>
            </h2>

            <p style="color: #475569; line-height: 1.75; margin-bottom: 1.25rem;">
              {post.data.description}
            </p>

            <a
              href={`/blog/${post.slug}/`}
              style="display: inline-block; background: #ea580c; color: white; text-decoration: none; padding: 12px 18px; border-radius: 12px; font-weight: 800;"
            >
              Read article
            </a>
          </article>
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav
          aria-label={`${categoryName} pagination`}
          style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 2.25rem;"
        >
          <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #94a3b8; font-weight: 800;">
            ← Prev
          </span>

          {Array.from({ length: totalPages }, (_, index) => index + 1).map(
            (page) =>
              page === currentPage ? (
                <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; background: #1b4332; color: white; font-weight: 900;">
                  {page}
                </span>
              ) : (
                <a
                  href={
                    page === 1
                      ? `/blog/category/${categorySlug}/`
                      : `/blog/category/${categorySlug}/page/${page}/`
                  }
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
                >
                  {page}
                </a>
              ),
          )}

          <a
            href={`/blog/category/${categorySlug}/page/2/`}
            style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
          >
            Next →
          </a>
        </nav>
      )
    }
  </main>
</MainLayout>
</file>

<file path="src/pages/blog/index.astro">
---
import MainLayout from "../../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../../config.js";
import { getCollection } from "astro:content";

const POSTS_PER_PAGE = 12;

const normalizeCategory = (value: string) => {
  const clean = value.trim().replace(/\s+/g, " ");

  const aliases: Record<string, string> = {
    "emergency storm": "Emergency & Storm",
    "emergency & storm": "Emergency & Storm",
    "florida laws & property risk": "Florida Laws & Property Risk",
    "tree care & cleanup": "Tree Care & Cleanup",
    "tree health & disease": "Tree Health & Disease",
    "landscaping & planting": "Landscaping & Planting",
    "local florida guides": "Local Florida Guides",
    "tree removal": "Tree Removal",
  };

  return aliases[clean.toLowerCase()] ?? clean;
};

const slugifyCategory = (value: string) =>
  normalizeCategory(value)
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-");

const allPosts = (await getCollection("blog", ({ data }) => !data.draft)).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);

const categories = [
  ...new Set(
    allPosts
      .map((post) => normalizeCategory(post.data.category))
      .filter(Boolean),
  ),
].sort();

const searchIndex = allPosts.map((post) => ({
  title: post.data.title,
  description: post.data.description,
  url: `/blog/${post.slug}/`,
  category: normalizeCategory(post.data.category),
  date: post.data.pubDate.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }),
  haystack:
    `${post.data.title} ${post.data.description} ${normalizeCategory(post.data.category)} ${(post.data.tags ?? []).join(" ")}`.toLowerCase(),
}));

const currentPage = 1;
const totalPosts = allPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);
const posts = allPosts.slice(0, POSTS_PER_PAGE);

const startPost = totalPosts === 0 ? 0 : 1;
const endPost = Math.min(POSTS_PER_PAGE, totalPosts);

const pageTitle = "Florida Tree Care Blog | ProTreeTrim";
const pageDescription =
  "Expert guides on tree removal, storm cleanup, stump grinding, and Florida tree care best practices.";
---

<MainLayout title={pageTitle} description={pageDescription}>
  <Fragment slot="head">
    <link rel="canonical" href={`${SITE_CONFIG.siteUrl}/blog/`} />
    {
      totalPages > 1 && (
        <link rel="next" href={`${SITE_CONFIG.siteUrl}/blog/page/2/`} />
      )
    }
  </Fragment>

  <header
    style="background: linear-gradient(135deg, #1b4332 0%, #081c15 100%); color: white; padding: 5rem 1.5rem; text-align: center; border-bottom: 5px solid #ea580c;"
  >
    <div class="container">
      <div
        style="font-size: 0.85rem; margin-bottom: 1rem; color: #ffb703; font-weight: 800; text-transform: uppercase;"
      >
        Florida Tree Care Knowledge Base
      </div>
      <h1
        style="font-size: clamp(2.4rem, 7vw, 4rem); margin: 0; font-weight: 900;"
      >
        ProTreeTrim Blog
      </h1>
      <p
        style="font-size: 1.15rem; color: #95d5b2; margin-top: 1rem; max-width: 760px; margin-left: auto; margin-right: auto;"
      >
        Practical Florida tree care guides for homeowners, HOAs, and property
        managers.
      </p>
    </div>
  </header>

  <main class="container" style="padding: 3rem 1.5rem 10rem;">
    <section style="max-width: 1100px; margin: 0 auto 1.5rem;">
      <div
        style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
      >
        <div
          style="display: grid; grid-template-columns: 1fr; gap: 18px; align-items: start;"
          class="blog-toolbar-grid"
        >
          <div>
            <label
              for="blogSearchInput"
              style="display: block; font-size: 0.8rem; font-weight: 800; color: #1b4332; text-transform: uppercase; margin-bottom: 0.6rem;"
            >
              Search articles
            </label>
            <div
              style="display: flex; align-items: center; gap: 10px; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 16px; padding: 0.85rem 1rem;"
            >
              <span style="font-size: 1rem;">🔎</span>
              <input
                id="blogSearchInput"
                type="search"
                placeholder="Search the full blog..."
                style="width: 100%; border: none; outline: none; background: transparent; font-size: 1rem; color: #0f172a;"
              />
            </div>
            <p
              id="blogSearchMeta"
              style="margin: 0.75rem 0 0; color: #64748b; font-size: 0.9rem;"
            >
              Showing {startPost}-{endPost} of {totalPosts} article(s).
            </p>
          </div>

          <div>
            <div
              style="font-size: 0.8rem; font-weight: 800; color: #1b4332; text-transform: uppercase; margin-bottom: 0.6rem;"
            >
              Browse by category
            </div>
            <div style="display: flex; gap: 10px; flex-wrap: wrap;">
              <a
                href="/blog/"
                style="background: #1b4332; color: white; padding: 10px 14px; border-radius: 999px; text-decoration: none; font-size: 0.78rem; font-weight: 800; text-transform: uppercase;"
              >
                All Posts
              </a>

              {
                categories.map((category) => (
                  <a
                    href={`/blog/category/${slugifyCategory(category)}/`}
                    style="background: #f8fafc; color: #1b4332; border: 1px solid #e2e8f0; padding: 10px 14px; border-radius: 999px; text-decoration: none; font-size: 0.78rem; font-weight: 800; text-transform: uppercase;"
                  >
                    {category}
                  </a>
                ))
              }
            </div>
          </div>
        </div>
      </div>
    </section>

    <section style="max-width: 1100px; margin: 0 auto;">
      {
        posts.length === 0 ? (
          <div style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 2rem; text-align: center;">
            <h2 style="margin-top: 0; color: #1b4332;">No blog posts yet</h2>
            <p style="color: #475569; margin-bottom: 0;">
              Add your first article inside <strong>src/content/blog/</strong>.
            </p>
          </div>
        ) : (
          <>
            <div
              id="blogNoResults"
              style="display: none; background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 2rem; text-align: center; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
            >
              <h2 style="margin-top: 0; color: #1b4332;">
                No matching articles found
              </h2>
              <p style="color: #475569; margin-bottom: 1rem;">
                No posts matched your search across the full blog.
              </p>
              <button
                id="clearBlogSearchBtn"
                type="button"
                style="background: #ea580c; color: white; border: none; padding: 12px 18px; border-radius: 12px; font-weight: 800; cursor: pointer;"
              >
                Clear search
              </button>
            </div>

            <div id="blogGlobalResults" style="display: none;">
              <div style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.25rem 1.5rem; margin-bottom: 1rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
                <h2 style="margin: 0 0 0.5rem; color: #1b4332; font-size: 1.4rem;">
                  Search results across the full blog
                </h2>
                <p
                  id="blogGlobalResultsCount"
                  style="margin: 0; color: #64748b;"
                />
              </div>

              <div
                id="blogGlobalResultsGrid"
                style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;"
              />
            </div>

            <div
              id="blogPostGrid"
              style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;"
            >
              {posts.map((post) => (
                <article
                  class="blog-card"
                  data-search={`${post.data.title} ${post.data.description} ${normalizeCategory(post.data.category)} ${(post.data.tags ?? []).join(" ")}`.toLowerCase()}
                  style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.75rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
                >
                  <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;">
                    <a
                      href={`/blog/category/${slugifyCategory(post.data.category)}/`}
                      style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; text-decoration: none;"
                    >
                      {normalizeCategory(post.data.category)}
                    </a>
                    <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
                      {post.data.pubDate.toLocaleDateString("en-US", {
                        year: "numeric",
                        month: "long",
                        day: "numeric",
                      })}
                    </span>
                  </div>

                  <h2 style="margin: 0 0 0.75rem; font-size: 1.55rem; line-height: 1.2;">
                    <a
                      href={`/blog/${post.slug}/`}
                      style="color: #1b4332; text-decoration: none; font-weight: 900;"
                    >
                      {post.data.title}
                    </a>
                  </h2>

                  <p style="color: #475569; line-height: 1.75; margin-bottom: 1.25rem;">
                    {post.data.description}
                  </p>

                  <a
                    href={`/blog/${post.slug}/`}
                    style="display: inline-block; background: #ea580c; color: white; text-decoration: none; padding: 12px 18px; border-radius: 12px; font-weight: 800;"
                  >
                    Read article
                  </a>
                </article>
              ))}
            </div>

            {totalPages > 1 && (
              <nav
                id="blogPagination"
                aria-label="Blog pagination"
                style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 2.25rem;"
              >
                <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #94a3b8; font-weight: 800;">
                  ← Prev
                </span>

                {Array.from(
                  { length: totalPages },
                  (_, index) => index + 1,
                ).map((page) =>
                  page === currentPage ? (
                    <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; background: #1b4332; color: white; font-weight: 900;">
                      {page}
                    </span>
                  ) : (
                    <a
                      href={page === 1 ? "/blog/" : `/blog/page/${page}/`}
                      style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
                    >
                      {page}
                    </a>
                  ),
                )}

                <a
                  href="/blog/page/2/"
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
                >
                  Next →
                </a>
              </nav>
            )}
          </>
        )
      }
    </section>
  </main>

  <script
    is:inline
    define:vars={{
      defaultMetaText: `Showing ${startPost}-${endPost} of ${totalPosts} article(s).`,
      searchIndex,
    }}
  >
    const searchInput = document.getElementById("blogSearchInput");
    const paginatedGrid = document.getElementById("blogPostGrid");
    const noResults = document.getElementById("blogNoResults");
    const searchMeta = document.getElementById("blogSearchMeta");
    const clearBtn = document.getElementById("clearBlogSearchBtn");
    const pagination = document.getElementById("blogPagination");
    const globalResults = document.getElementById("blogGlobalResults");
    const globalResultsGrid = document.getElementById("blogGlobalResultsGrid");
    const globalResultsCount = document.getElementById(
      "blogGlobalResultsCount",
    );

    const escapeHtml = (value = "") =>
      String(value)
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const renderSearchResults = (matches) => {
      if (!globalResultsGrid) return;

      globalResultsGrid.innerHTML = matches
        .map(
          (item) => `
            <article style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.75rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
              <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;">
                <a
                  href="/blog/category/${escapeHtml(
                    item.category
                      .toLowerCase()
                      .trim()
                      .replace(/&/g, "and")
                      .replace(/[^a-z0-9\\s-]/g, "")
                      .replace(/\\s+/g, "-"),
                  )}/"
                  style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; text-decoration: none;"
                >
                  ${escapeHtml(item.category)}
                </a>
                <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
                  ${escapeHtml(item.date)}
                </span>
              </div>

              <h2 style="margin: 0 0 0.75rem; font-size: 1.55rem; line-height: 1.2;">
                <a
                  href="${escapeHtml(item.url)}"
                  style="color: #1b4332; text-decoration: none; font-weight: 900;"
                >
                  ${escapeHtml(item.title)}
                </a>
              </h2>

              <p style="color: #475569; line-height: 1.75; margin-bottom: 1.25rem;">
                ${escapeHtml(item.description)}
              </p>

              <a
                href="${escapeHtml(item.url)}"
                style="display: inline-block; background: #ea580c; color: white; text-decoration: none; padding: 12px 18px; border-radius: 12px; font-weight: 800;"
              >
                Read article
              </a>
            </article>
          `,
        )
        .join("");
    };

    const updateBlogSearch = () => {
      const query = (searchInput?.value || "").trim().toLowerCase();

      if (!query) {
        if (paginatedGrid) paginatedGrid.style.display = "grid";
        if (pagination) pagination.style.display = "flex";
        if (globalResults) globalResults.style.display = "none";
        if (noResults) noResults.style.display = "none";
        if (searchMeta) searchMeta.textContent = defaultMetaText;
        return;
      }

      const matches = searchIndex.filter((item) =>
        item.haystack.includes(query),
      );

      if (searchMeta) {
        searchMeta.textContent = `Showing ${matches.length} result(s) across the full blog for "${query}".`;
      }

      if (paginatedGrid) paginatedGrid.style.display = "none";
      if (pagination) pagination.style.display = "none";

      if (matches.length === 0) {
        if (globalResults) globalResults.style.display = "none";
        if (noResults) noResults.style.display = "block";
        return;
      }

      renderSearchResults(matches);

      if (globalResultsCount) {
        globalResultsCount.textContent = `${matches.length} article(s) matched your search.`;
      }

      if (noResults) noResults.style.display = "none";
      if (globalResults) globalResults.style.display = "block";
    };

    searchInput?.addEventListener("input", updateBlogSearch);

    clearBtn?.addEventListener("click", () => {
      if (searchInput) searchInput.value = "";
      updateBlogSearch();
      searchInput?.focus();
    });
  </script>

  <style>
    .blog-toolbar-grid {
      grid-template-columns: 1fr;
    }
  </style>
</MainLayout>
</file>

<file path="generate-sitemaps.mjs">
import fs from 'fs';
import path from 'path';
import { parse } from 'csv-parse/sync';

// --- AYARLAR ---
const SITE_URL = 'https://www.protreetrim.com';
const CSV_PATH = path.join(process.cwd(), 'src/data/cities.csv');
const PUBLIC_PATH = path.join(process.cwd(), 'public');
const TODAY = new Date().toISOString().split('T')[0];

async function generate() {
    console.log('🚀 Public klasörüne sitemap oluşturuluyor...');

    try {
        // 1. Verileri Oku
        const fileContent = fs.readFileSync(CSV_PATH, 'utf-8');
        const records = parse(fileContent, { columns: true, skip_empty_lines: true, bom: true });

        // 2. Statik Sayfalar İçin Ana Sitemap
        const staticPages = [
            '', '/about', '/contact', '/services', '/gallery', 
            '/trust-safety', '/privacy', '/join-network',
            '/services/tree-removal', '/services/tree-trimming', 
            '/services/stump-grinding', '/services/emergency-response',
            '/services/land-clearing', '/services/commercial-services'
        ];

        let mainXml = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">`;
        staticPages.forEach(page => {
            mainXml += `\n  <url>\n    <loc>${SITE_URL}${page}</loc>\n    <lastmod>${TODAY}</lastmod>\n    <priority>${page === '' ? '1.0' : '0.8'}</priority>\n  </url>`;
        });
        mainXml += `\n</urlset>`;
        fs.writeFileSync(path.join(PUBLIC_PATH, 'sitemap-main.xml'), mainXml);

        // 3. İlçelere Göre Grupla ve Dinamik Sayfaları Oluştur
        const countyGroups = {};
        records.forEach(row => {
            if (!row.County) return;
            const county = row.County.toLowerCase().trim().replace(/\s+/g, '-');
            if (!countyGroups[county]) countyGroups[county] = [];
            countyGroups[county].push(row);
        });

        const services = [
            { prefix: 'tree-removal' },
            { prefix: 'stump-grinding' },
            { prefix: 'emergency-service' }
        ];

        const sitemapFiles = ['sitemap-main.xml'];

        Object.keys(countyGroups).forEach(countySlug => {
            let xml = `<?xml version="1.0" encoding="UTF-8"?>\n<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">`;
            
            // İlçe Hub Sayfası
            xml += `\n  <url>\n    <loc>${SITE_URL}/county/${countySlug}</loc>\n    <lastmod>${TODAY}</lastmod>\n    <priority>0.9</priority>\n  </url>`;

            countyGroups[countySlug].forEach(city => {
                if (!city.City) return;
                const citySlug = city.City.toLowerCase().trim().replace(/\./g, '').replace(/\s+/g, '-');
                services.forEach(svc => {
                    xml += `\n  <url>\n    <loc>${SITE_URL}/${svc.prefix}-${citySlug}</loc>\n    <lastmod>${TODAY}</lastmod>\n    <priority>0.7</priority>\n  </url>`;
                });
            });

            xml += `\n</urlset>`;
            const fileName = `sitemap-county-${countySlug}.xml`;
            fs.writeFileSync(path.join(PUBLIC_PATH, fileName), xml);
            sitemapFiles.push(fileName);
        });

        // 4. Ana sitemap-index.xml Dosyasını Oluştur
        let indexXml = `<?xml version="1.0" encoding="UTF-8"?>\n<sitemapindex xmlns="http://www.sitemaps.org/schemas/sitemap/0.9">`;
        sitemapFiles.forEach(file => {
            indexXml += `\n  <sitemap>\n    <loc>${SITE_URL}/${file}</loc>\n    <lastmod>${TODAY}</lastmod>\n  </sitemap>`;
        });
        indexXml += `\n</sitemapindex>`;
        
        fs.writeFileSync(path.join(PUBLIC_PATH, 'sitemap-index.xml'), indexXml);
        console.log(`✅ TAMAMLANDI: Toplam ${sitemapFiles.length} sitemap dosyası PUBLIC klasörüne yazıldı.`);

    } catch (err) {
        console.error('❌ HATA:', err.message);
        process.exit(1);
    }
}

generate();
</file>

