---
const { title = "", category = "", tags = [], slug = "" } = Astro.props;

const text = [title, category, slug, ...(Array.isArray(tags) ? tags : [])]
  .join(" ")
  .toLowerCase();

const includesAny = (terms) => terms.some((term) => text.includes(term));

const emergencyTerms = [
  "emergency",
  "storm",
  "hurricane",
  "wind",
  "leaning",
  "uprooted",
  "crack",
  "split",
  "fallen",
  "roof",
  "power line",
  "blocked",
  "hazard",
  "dangerous",
  "lightning",
];

const problemTreeTerms = [
  "invasive",
  "brazilian pepper",
  "melaleuca",
  "australian pine",
  "ficus",
  "camphor",
  "chinaberry",
  "problem tree",
  "pest",
  "beetle",
  "whitefly",
  "fungus",
  "mushroom",
  "disease",
  "rot",
  "laurel wilt",
  "ganoderma",
  "oak wilt",
  "sooty mold",
  "scale insects",
];

const advisorTerms = [
  "stump",
  "root",
  "roots",
  "driveway",
  "pool",
  "pavers",
  "fence",
  "sidewalk",
  "planting",
  "mulch",
  "watering",
  "palm",
  "oak",
  "trim",
  "prune",
  "pruning",
  "tree care",
  "access",
  "estimate",
  "quote",
];

const permitTerms = [
  "permit",
  "ordinance",
  "statute",
  "hoa",
  "protected",
  "mangrove",
  "neighbor",
  "liability",
  "insurance",
  "easement",
  "right-of-way",
  "property line",
  "documentation",
];

let profile = {
  eyebrow: "Florida homeowner tool",
  title: "Not sure what to check next?",
  description:
    "Use ProTreeTrim’s Florida tree care tools to organize the next step before comparing service options, reviewing a risky tree, or calling dispatch.",
  tools: [
    {
      label: "Open Tree Care Advisor",
      href: "/tools/florida-tree-care-advisor/",
      note: "Match your area, property concern, and next step.",
      tone: "primary",
    },
    {
      label: "View Problem Tree Guide",
      href: "/tools/florida-problem-tree-guide/",
      note: "Check invasive, storm-prone, messy, or hardscape-conflict trees.",
      tone: "secondary",
    },
  ],
};

if (includesAny(emergencyTerms)) {
  profile = {
    eyebrow: "Storm and safety tool",
    title: "Is this tree situation urgent?",
    description:
      "If a tree is cracked, leaning, uprooted, blocking access, resting on a structure, or near utility lines, keep people away and use the emergency checklist before approaching the area.",
    tools: [
      {
        label: "Open Emergency Checklist",
        href: "/tools/emergency-tree-safety-checklist/",
        note: "Sort the situation into emergency, priority, or monitor-and-plan.",
        tone: "danger",
      },
      {
        label: "Call Dispatch",
        href: "tel:+18554982578",
        note: "+1 855 498 2578 for active hazards or blocked access.",
        tone: "primary",
      },
      {
        label: "Open Tree Care Advisor",
        href: "/tools/florida-tree-care-advisor/",
        note: "Get Florida-specific next-step guidance.",
        tone: "secondary",
      },
    ],
  };
} else if (includesAny(permitTerms)) {
  profile = {
    eyebrow: "Permit and documentation helper",
    title: "Planning tree work around rules or documentation?",
    description:
      "Florida tree rules can vary by city, county, HOA, protected area, species, and tree condition. Use the tools hub to compare safer planning paths before non-emergency removal.",
    tools: [
      {
        label: "Explore Tools Hub",
        href: "/tools/",
        note: "Find county permit notes, safety checklists, and planning tools.",
        tone: "primary",
      },
      {
        label: "Open Tree Care Advisor",
        href: "/tools/florida-tree-care-advisor/",
        note: "Match the concern to practical homeowner next steps.",
        tone: "secondary",
      },
    ],
  };
} else if (includesAny(problemTreeTerms)) {
  profile = {
    eyebrow: "Problem tree guide",
    title: "Trying to identify a Florida tree problem?",
    description:
      "Some Florida trees are invasive, brittle, messy, pest-prone, or difficult near homes, pools, fences, and driveways. Use the guide before planning removal or cleanup.",
    tools: [
      {
        label: "View Problem Tree Guide",
        href: "/tools/florida-problem-tree-guide/",
        note: "Compare watch-for clues, risk notes, and planning options.",
        tone: "primary",
      },
      {
        label: "Open Tree Care Advisor",
        href: "/tools/florida-tree-care-advisor/",
        note: "Get region-aware Florida care guidance.",
        tone: "secondary",
      },
    ],
  };
} else if (includesAny(advisorTerms)) {
  profile = {
    eyebrow: "Florida planning tool",
    title: "Need a clearer next step for this tree issue?",
    description:
      "Use the Florida Tree Care Advisor to connect your region, property type, and concern to practical homeowner guidance before requesting service.",
    tools: [
      {
        label: "Open Tree Care Advisor",
        href: "/tools/florida-tree-care-advisor/",
        note: "Helpful for roots, palms, stumps, access limits, trimming, and removal planning.",
        tone: "primary",
      },
      {
        label: "View All Tools",
        href: "/tools/",
        note: "Compare advisor, safety checklist, and problem tree guide.",
        tone: "secondary",
      },
    ],
  };
}
---

<aside class="blog-tools-cta" aria-label="Florida tree care tools">
  <div class="blog-tools-cta__copy">
    <span>{profile.eyebrow}</span>
    <h2>{profile.title}</h2>
    <p>{profile.description}</p>
  </div>
  <div class="blog-tools-cta__grid">
    {profile.tools.map((tool) => (
      <a class:list={["blog-tools-cta__tool", `blog-tools-cta__tool--${tool.tone}`]} href={tool.href} aria-label={`${tool.label}: ${tool.note}`}>
        <strong>{tool.label} →</strong>
        <small>{tool.note}</small>
      </a>
    ))}
  </div>
</aside>

<style>
  .blog-tools-cta {
    margin-top: 2.5rem;
    padding: clamp(1.25rem, 3vw, 1.75rem);
    border-radius: 24px;
    background:
      radial-gradient(circle at top right, rgba(242, 90, 6, 0.16), transparent 28%),
      linear-gradient(135deg, #0f3f2a 0%, #123f2e 52%, #082d20 100%);
    color: #fff;
    border: 1px solid rgba(187, 247, 208, 0.18);
    box-shadow: 0 18px 45px rgba(8, 45, 32, 0.18);
  }

  .blog-tools-cta__copy span {
    display: inline-flex;
    margin-bottom: 0.7rem;
    color: #ffb703;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.14em;
  }

  .blog-tools-cta__copy h2 {
    margin: 0 0 0.55rem;
    color: #fff;
    font-size: clamp(1.45rem, 3vw, 2rem);
    line-height: 1.1;
  }

  .blog-tools-cta__copy p {
    margin: 0;
    color: #d9fbe5;
    line-height: 1.7;
  }

  .blog-tools-cta__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(190px, 1fr));
    gap: 0.85rem;
    margin-top: 1.25rem;
  }

  .blog-tools-cta__tool {
    display: block;
    padding: 1rem;
    border-radius: 18px;
    text-decoration: none;
    background: rgba(255, 255, 255, 0.08);
    border: 1px solid rgba(255, 255, 255, 0.16);
    color: inherit;
    transition: transform 160ms ease, background 160ms ease, border-color 160ms ease;
  }

  .blog-tools-cta__tool:hover {
    transform: translateY(-2px);
    background: rgba(255, 255, 255, 0.13);
    border-color: rgba(255, 255, 255, 0.32);
  }

  .blog-tools-cta__tool strong {
    display: block;
    color: #fff;
    font-size: 0.98rem;
    line-height: 1.25;
  }

  .blog-tools-cta__tool small {
    display: block;
    margin-top: 0.45rem;
    color: #c8f7d7;
    line-height: 1.5;
    font-size: 0.82rem;
  }

  .blog-tools-cta__tool--primary,
  .blog-tools-cta__tool--danger {
    background: #f25a06;
    border-color: #f25a06;
    box-shadow: 0 16px 30px rgba(242, 90, 6, 0.22);
  }

  .blog-tools-cta__tool--primary small,
  .blog-tools-cta__tool--danger small {
    color: #fff7ed;
  }

  .blog-tools-cta__tool--secondary {
    background: rgba(232, 255, 241, 0.95);
    color: #0f3f2a;
  }

  .blog-tools-cta__tool--secondary strong {
    color: #0f3f2a;
  }

  .blog-tools-cta__tool--secondary small {
    color: #3f6b56;
  }

  @media (max-width: 640px) {
    .blog-tools-cta__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
