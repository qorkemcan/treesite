---
import { SITE_CONFIG } from "../config.js";
import siteAlert from "../data/site-alert.json";

const alert = siteAlert || {};
const enabled = alert.enabled === true && alert.mode !== "normal";
const severity = alert.severity || "medium";
const tone = severity === "high" ? "high" : severity === "medium" ? "medium" : "low";
const headline = alert.headline || "Florida Tree Safety Advisory";
const message = alert.message || "Weather conditions may affect tree safety in parts of Florida.";
const areas = Array.isArray(alert.areas) ? alert.areas.filter(Boolean).slice(0, 5) : [];
const updatedAt = alert.updatedAt ? new Date(alert.updatedAt) : null;
const updatedLabel = updatedAt && !Number.isNaN(updatedAt.getTime())
  ? updatedAt.toLocaleString("en-US", { month: "short", day: "numeric", hour: "numeric", minute: "2-digit" })
  : "recently";
const ctaHref = alert.ctaHref || SITE_CONFIG.phoneHref;
const ctaText = alert.ctaText || "Call Dispatch";
---

{enabled && (
  <section class={`weather-alert weather-alert--${tone}`} aria-label="Florida tree safety weather advisory">
    <div class="weather-alert__inner">
      <div class="weather-alert__icon" aria-hidden="true">⚠️</div>
      <div class="weather-alert__copy">
        <div class="weather-alert__eyebrow">Florida weather-aware tree safety</div>
        <strong>{headline}</strong>
        <p>{message}</p>
        {areas.length > 0 && (
          <p class="weather-alert__areas">Affected areas noted: {areas.join(", ")}</p>
        )}
        <p class="weather-alert__meta">Updated {updatedLabel}. Always follow official local weather and emergency guidance.</p>
      </div>
      <a class="weather-alert__cta" href={ctaHref}>{ctaText}</a>
    </div>
  </section>
)}

<style>
  .weather-alert {
    background: #fff7ed;
    border-bottom: 1px solid rgba(234, 88, 12, 0.22);
    color: #1f2937;
  }
  .weather-alert--high {
    background: linear-gradient(135deg, #7f1d1d 0%, #991b1b 100%);
    color: #fff;
    border-bottom-color: rgba(255, 255, 255, 0.18);
  }
  .weather-alert--medium {
    background: linear-gradient(135deg, #fff7ed 0%, #ffedd5 100%);
  }
  .weather-alert__inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 14px 1.2rem;
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: 14px;
    align-items: center;
  }
  .weather-alert__icon {
    width: 40px;
    height: 40px;
    border-radius: 999px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(234, 88, 12, 0.15);
    font-size: 1.15rem;
  }
  .weather-alert--high .weather-alert__icon {
    background: rgba(255, 255, 255, 0.16);
  }
  .weather-alert__copy strong {
    display: block;
    font-size: 0.95rem;
    line-height: 1.2;
    font-weight: 900;
    margin-bottom: 3px;
  }
  .weather-alert__eyebrow {
    font-size: 0.64rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: #c2410c;
    margin-bottom: 3px;
  }
  .weather-alert--high .weather-alert__eyebrow {
    color: #fed7aa;
  }
  .weather-alert__copy p {
    margin: 0;
    font-size: 0.82rem;
    line-height: 1.45;
    color: inherit;
  }
  .weather-alert__areas {
    margin-top: 4px !important;
    font-weight: 700;
  }
  .weather-alert__meta {
    margin-top: 4px !important;
    opacity: 0.72;
    font-size: 0.7rem !important;
  }
  .weather-alert__cta {
    white-space: nowrap;
    background: #ea580c;
    color: white !important;
    text-decoration: none;
    font-weight: 900;
    border-radius: 999px;
    padding: 10px 15px;
    font-size: 0.78rem;
    box-shadow: 0 8px 20px rgba(234, 88, 12, 0.22);
  }
  .weather-alert--high .weather-alert__cta {
    background: #ffb703;
    color: #1b1b1b !important;
  }
  @media (max-width: 760px) {
    .weather-alert__inner {
      grid-template-columns: auto 1fr;
      align-items: start;
    }
    .weather-alert__cta {
      grid-column: 1 / -1;
      text-align: center;
      width: 100%;
    }
  }
</style>
