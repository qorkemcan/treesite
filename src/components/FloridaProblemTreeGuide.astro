---
import guideData from "../data/florida-problem-trees.json";

const categories = guideData.categories;
const trees = guideData.trees;
const services = guideData.services;
const guides = guideData.guides;
const defaultTree = trees[0];
---

<section class="problem-tool-wrap" id="problem-tree-guide" aria-labelledby="problem-tree-guide-title">
  <div class="problem-tool-intro">
    <div>
      <p class="eyebrow">Florida problem tree guide</p>
      <h2 id="problem-tree-guide-title">Check whether a Florida tree may become a property problem.</h2>
      <p>
        Some trees are only a problem in the wrong place: near a pool cage, driveway,
        fence, roofline, septic area, or coastal exposure. Others are known for aggressive
        spread, brittle limbs, messy fruit, or repeated maintenance needs.
      </p>
    </div>
    <div class="disclaimer-card">
      <strong>Homeowner education only.</strong>
      <span>{guideData.disclaimer}</span>
    </div>
  </div>

  <div class="problem-tool-card">
    <aside class="problem-picker">
      <label for="problem-tree-select">Select a tree or issue</label>
      <select id="problem-tree-select" name="problem_tree" aria-describedby="problem-tree-guide-title">
        {trees.map((tree) => (
          <option value={tree.id}>{tree.name}</option>
        ))}
      </select>

      <div class="category-list" aria-label="Problem tree categories">
        <p>Common concern types</p>
        {categories.map((category) => (
          <button type="button" class="category-chip" data-category={category.id} aria-pressed="false">
            {category.label}
          </button>
        ))}
      </div>

      <div class="safe-note">
        <p>Before you call, note:</p>
        <ul>
          <li>Tree location and nearby structures</li>
          <li>Recent storm damage or sudden lean</li>
          <li>Root conflicts near hardscape</li>
          <li>Photos taken from a safe distance</li>
        </ul>
      </div>
    </aside>

    <article class="problem-result" aria-live="polite" aria-atomic="true">
      <div class="result-topline" id="treeCategoryLabel">Invasive or aggressive spreaders</div>
      <h3 id="treeName">{defaultTree.name}</h3>
      <p class="scientific" id="treeScientific">{defaultTree.scientificName}</p>

      <div class="result-metrics">
        <div>
          <span>Concern level</span>
          <strong id="riskLevel">{defaultTree.riskLevel}</strong>
        </div>
        <div>
          <span>Most relevant service</span>
          <strong id="primaryService">Tree removal planning</strong>
        </div>
      </div>

      <div class="result-section">
        <h4>Why it matters in Florida yards</h4>
        <p id="whyItMatters">{defaultTree.whyItMatters}</p>
      </div>

      <div class="result-grid">
        <div class="result-section compact">
          <h4>Watch for</h4>
          <ul id="watchForList">
            {defaultTree.watchFor.map((item) => <li>{item}</li>)}
          </ul>
        </div>
        <div class="result-section compact highlighted">
          <h4>Homeowner next step</h4>
          <p id="homeownerNextStep">{defaultTree.homeownerNextStep}</p>
        </div>
      </div>

      <div class="link-groups">
        <div>
          <h4>Service planning</h4>
          <div class="pill-links" id="serviceLinks"></div>
        </div>
        <div>
          <h4>Related guides</h4>
          <div class="guide-links" id="guideLinks"></div>
        </div>
      </div>
    </article>
  </div>

  <div class="problem-followup-cta">
    <div>
      <p class="eyebrow">Not sure where to start?</p>
      <h3>Use this guide with the Florida Tree Care Advisor.</h3>
      <p>
        If you are comparing tree symptoms, access issues, storm risk, or permit questions,
        the advisor can help organize your next step before you call a provider.
      </p>
    </div>
    <div class="followup-actions">
      <a href="/tools/florida-tree-care-advisor/">Open Tree Care Advisor</a>
      <a href="tel:+18554982578" class="call" aria-label="Call ProTreeTrim dispatch">Call Dispatch</a>
    </div>
  </div>
</section>

<script define:vars={{ trees, categories, services, guides }}>
  const treeSelect = document.getElementById('problem-tree-select');
  const categoryButtons = Array.from(document.querySelectorAll('.category-chip'));
  const byId = Object.fromEntries(trees.map((tree) => [tree.id, tree]));
  const categoryById = Object.fromEntries(categories.map((category) => [category.id, category]));

  function createLink(item, className = '') {
    const a = document.createElement('a');
    a.href = item.href;
    a.textContent = item.label;
    a.className = className;
    a.setAttribute('aria-label', item.label);
    return a;
  }

  function renderLinks(containerId, keys, source, className) {
    const container = document.getElementById(containerId);
    container.innerHTML = '';
    keys
      .map((key) => source[key])
      .filter(Boolean)
      .forEach((item) => container.appendChild(createLink(item, className)));
  }

  function setActiveCategory(categoryId) {
    categoryButtons.forEach((button) => {
      const isActive = button.dataset.category === categoryId;
      button.classList.toggle('active', isActive);
      button.setAttribute('aria-pressed', String(isActive));
    });
  }

  function renderTree(treeId) {
    const tree = byId[treeId] || trees[0];
    const category = categoryById[tree.category];
    document.getElementById('treeCategoryLabel').textContent = category?.label || 'Florida tree issue';
    document.getElementById('treeName').textContent = tree.name;
    document.getElementById('treeScientific').textContent = tree.scientificName;
    document.getElementById('riskLevel').textContent = tree.riskLevel;
    document.getElementById('primaryService').textContent = services[tree.serviceFit?.[0]]?.label || 'Tree service planning';
    document.getElementById('whyItMatters').textContent = tree.whyItMatters;
    document.getElementById('homeownerNextStep').textContent = tree.homeownerNextStep;

    const watchList = document.getElementById('watchForList');
    watchList.innerHTML = '';
    tree.watchFor.forEach((item) => {
      const li = document.createElement('li');
      li.textContent = item;
      watchList.appendChild(li);
    });

    renderLinks('serviceLinks', tree.serviceFit || [], services, 'service-pill');
    renderLinks('guideLinks', tree.relatedGuides || [], guides, 'guide-pill');
    setActiveCategory(tree.category);
  }

  treeSelect?.addEventListener('change', (event) => renderTree(event.target.value));
  categoryButtons.forEach((button) => {
    button.addEventListener('click', () => {
      const firstMatch = trees.find((tree) => tree.category === button.dataset.category);
      if (!firstMatch) return;
      treeSelect.value = firstMatch.id;
      renderTree(firstMatch.id);
    });
  });

  renderTree(treeSelect?.value || trees[0].id);
</script>

<style>
  .problem-tool-wrap {
    padding: 5rem 1.5rem 7rem;
    background: #f8faf9;
  }

  .problem-tool-intro,
  .problem-tool-card {
    max-width: 1180px;
    margin: 0 auto;
  }

  .problem-tool-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(300px, 0.8fr);
    gap: 2rem;
    align-items: end;
    margin-bottom: 2rem;
  }

  .eyebrow {
    color: #f25a06;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    font-size: 0.8rem;
    margin: 0 0 0.8rem;
  }

  .problem-tool-intro h2 {
    font-size: clamp(2rem, 4vw, 3.5rem);
    line-height: 1;
    color: #0f3f2a;
    margin: 0 0 1rem;
    letter-spacing: -0.04em;
  }

  .problem-tool-intro p {
    color: #475569;
    font-size: 1.05rem;
    line-height: 1.8;
    margin: 0;
  }

  .disclaimer-card {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 1.25rem;
    padding: 1.5rem;
    color: #9a3412;
    display: grid;
    gap: 0.5rem;
    line-height: 1.6;
  }

  .problem-tool-card {
    display: grid;
    grid-template-columns: 380px minmax(0, 1fr);
    border-radius: 2rem;
    overflow: hidden;
    border: 1px solid #dbe4df;
    box-shadow: 0 25px 80px rgba(15, 63, 42, 0.08);
    background: #fff;
  }

  .problem-picker {
    background: linear-gradient(180deg, #082d20 0%, #0d3b2a 100%);
    padding: 2.25rem;
    color: #d1fae5;
  }

  .problem-picker label,
  .category-list p,
  .safe-note p {
    display: block;
    color: #b7f7cf;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    font-size: 0.78rem;
    margin: 0 0 0.75rem;
  }

  .problem-picker select {
    width: 100%;
    border: 1px solid rgba(255,255,255,0.22);
    background: rgba(255,255,255,0.08);
    color: #fff;
    border-radius: 1rem;
    padding: 1rem 1rem;
    font: inherit;
    font-weight: 800;
    margin-bottom: 2rem;
  }

  .problem-picker option {
    color: #111827;
  }

  .category-list {
    display: grid;
    gap: 0.75rem;
    margin-bottom: 2rem;
  }

  .category-chip {
    text-align: left;
    border: 1px solid rgba(255,255,255,0.18);
    background: rgba(255,255,255,0.06);
    color: #fff;
    border-radius: 999px;
    padding: 0.75rem 1rem;
    font-weight: 800;
    cursor: pointer;
  }

  .category-chip.active,
  .category-chip:hover {
    background: #f25a06;
    border-color: #f25a06;
  }

  .safe-note {
    background: rgba(255,255,255,0.07);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 1rem;
    padding: 1.2rem;
  }

  .safe-note ul {
    margin: 0;
    padding-left: 1.1rem;
    line-height: 1.8;
    color: rgba(255,255,255,0.82);
  }

  .problem-result {
    padding: clamp(2rem, 4vw, 3rem);
    color: #123d2b;
  }

  .result-topline {
    color: #f25a06;
    text-transform: uppercase;
    font-size: 0.8rem;
    font-weight: 900;
    letter-spacing: 0.1em;
    margin-bottom: 0.6rem;
  }

  .problem-result h3 {
    font-size: clamp(2rem, 4vw, 3.3rem);
    line-height: 1;
    margin: 0;
    letter-spacing: -0.04em;
  }

  .scientific {
    color: #64748b;
    font-style: italic;
    margin: 0.65rem 0 1.5rem;
  }

  .result-metrics,
  .result-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1rem;
  }

  .result-metrics div {
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: 1rem;
    padding: 1rem;
  }

  .result-metrics span {
    display: block;
    color: #15803d;
    font-size: 0.75rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }

  .result-metrics strong {
    font-size: 1.1rem;
  }

  .result-section {
    margin-top: 2rem;
    border-top: 1px solid #e2e8f0;
    padding-top: 1.5rem;
  }

  .result-section h4,
  .link-groups h4 {
    margin: 0 0 0.8rem;
    color: #0f3f2a;
    font-size: 1.15rem;
  }

  .result-section p,
  .result-section li {
    color: #475569;
    line-height: 1.75;
  }

  .compact {
    border: 1px solid #e2e8f0;
    border-radius: 1rem;
    padding: 1.25rem;
  }

  .compact ul {
    margin-bottom: 0;
  }

  .highlighted {
    background: #fff7ed;
    border-color: #fed7aa;
  }

  .link-groups {
    margin-top: 2rem;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .pill-links,
  .guide-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  .pill-links :global(a),
  .guide-links :global(a) {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.35rem;
    border-radius: 999px;
    padding: 0.75rem 1rem;
    font-weight: 900;
    text-decoration: none;
    line-height: 1;
    transition: transform 0.16s ease, box-shadow 0.16s ease, border-color 0.16s ease;
  }

  .pill-links :global(a)::after,
  .guide-links :global(a)::after {
    content: "→";
    font-weight: 900;
  }

  .pill-links :global(a) {
    background: #f25a06;
    color: #fff;
    box-shadow: 0 12px 24px rgba(242, 90, 6, 0.18);
  }

  .guide-links :global(a) {
    background: #f8fafc;
    color: #0f3f2a;
    border: 1px solid #dbe4df;
  }

  .pill-links :global(a:hover),
  .guide-links :global(a:hover) {
    transform: translateY(-1px);
  }

  .problem-followup-cta {
    max-width: 1180px;
    margin: 2rem auto 0;
    display: grid;
    grid-template-columns: minmax(0, 1fr) auto;
    gap: 1.5rem;
    align-items: center;
    background: #fff;
    border: 1px solid #dbe4df;
    border-radius: 1.5rem;
    padding: clamp(1.5rem, 3vw, 2rem);
    box-shadow: 0 18px 60px rgba(15, 63, 42, 0.07);
  }

  .problem-followup-cta h3 {
    color: #0f3f2a;
    font-size: clamp(1.5rem, 3vw, 2.4rem);
    line-height: 1.05;
    margin: 0 0 0.75rem;
    letter-spacing: -0.035em;
  }

  .problem-followup-cta p:not(.eyebrow) {
    color: #475569;
    margin: 0;
    line-height: 1.7;
    max-width: 720px;
  }

  .followup-actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .followup-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 999px;
    padding: 0.95rem 1.15rem;
    font-weight: 900;
    text-decoration: none;
    background: #ecfdf5;
    color: #0f3f2a;
    border: 1px solid #bbf7d0;
  }

  .followup-actions a.call {
    background: #f25a06;
    border-color: #f25a06;
    color: #fff;
  }

  @media (max-width: 900px) {
    .problem-tool-intro,
    .problem-tool-card,
    .result-metrics,
    .result-grid,
    .link-groups,
    .problem-followup-cta {
      grid-template-columns: 1fr;
    }

    .followup-actions {
      justify-content: flex-start;
    }
  }
</style>
