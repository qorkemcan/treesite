---
const { blocks, cityName, serviceName } = Astro.props;
---

{
  blocks.length > 0 && (
    <section
      aria-labelledby="generic-route-enrichment-title"
      style="margin-top:3rem; padding-top:2rem; border-top:1px solid #dbe7df;"
    >
      <header>
        <p style="margin:0 0 0.5rem; color:#166534; font-size:0.78rem; font-weight:800; text-transform:uppercase;">
          Homeowner planning notes
        </p>
        <h2
          id="generic-route-enrichment-title"
          style="margin:0; color:#064e3b; font-size:1.75rem;"
        >
          {serviceName} considerations for {cityName}
        </h2>
      </header>
      <div style="display:grid; grid-template-columns:repeat(auto-fit, minmax(240px, 1fr)); gap:1.5rem; margin-top:1.5rem;">
        {blocks.map((block) => (
          <article style="padding-left:1rem; border-left:3px solid #16a34a;">
            <h3 style="margin:0 0 0.55rem; color:#14532d; font-size:1.05rem;">
              {block.title}
            </h3>
            {block.notes.map((note) => (
              <p style="margin:0.5rem 0 0; color:#475569; line-height:1.7;">{note}</p>
            ))}
          </article>
        ))}
      </div>
    </section>
  )
}
