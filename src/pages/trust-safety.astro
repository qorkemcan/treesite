---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config.js";

const safetyQuestions = [
  {
    question: "Should I wait or request help now?",
    answer:
      "If a tree is moving, splitting, touching a structure, blocking access, or near utility lines, stay away from the area and ask for guidance before cleanup is attempted.",
  },
  {
    question: "Can the tree be saved?",
    answer:
      "Sometimes trimming, support, or monitoring is more appropriate than removal. The right answer depends on species, defects, location, and property risk.",
  },
  {
    question: "Do I need permits?",
    answer:
      "Permit rules vary by city, county, tree type, and property situation. Homeowners should confirm current local requirements before authorizing regulated work.",
  },
  {
    question: "Should I call my insurance company first?",
    answer:
      "For storm damage, structural impact, or documentation needs, it can be helpful to contact your insurer and keep photos before work begins when it is safe to do so.",
  },
];
---

<MainLayout
  title="Trust & Safety for Florida Tree Service Requests"
  description="Learn how ProTreeTrim approaches tree service safety, transparency, homeowner responsibility, storm response, and local provider matching across Florida."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "AboutPage",
        name: "Trust & Safety for Florida Tree Service Requests",
        description:
          "Information about ProTreeTrim's approach to tree service safety, transparency, homeowner responsibility, storm response, and local provider matching.",
        url: `${SITE_CONFIG.siteUrl}/trust-safety/`,
        mainEntity: {
          "@type": "Organization",
          name: SITE_CONFIG.brandName,
          telephone: SITE_CONFIG.phoneHref.replace("tel:", ""),
          email: SITE_CONFIG.email,
          areaServed: {
            "@type": "State",
            name: "Florida",
          },
        },
      })}
    />
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "FAQPage",
        mainEntity: safetyQuestions.map((item) => ({
          "@type": "Question",
          name: item.question,
          acceptedAnswer: {
            "@type": "Answer",
            text: item.answer,
          },
        })),
      })}
    />
  </Fragment>

  <header class="trust-hero">
    <div class="container">
      <p class="eyebrow">Trust & safety</p>
      <h1>Helping Florida Homeowners Make Safer Tree Decisions</h1>
      <p>
        Tree work can involve property risk, weather conditions, local rules,
        and safety questions. This page explains how ProTreeTrim approaches
        dispatch, communication, and homeowner responsibility without pressure
        or exaggerated promises.
      </p>
    </div>
  </header>

  <main class="container trust-main">
    <section class="principles" aria-labelledby="approach-title">
      <div class="section-heading">
        <p>How we approach safety</p>
        <h2 id="approach-title">Factual principles before any recommendation</h2>
      </div>
      <div class="principle-grid">
        <article>
          <span aria-hidden="true">01</span>
          <h3>Safety before speed</h3>
          <p>
            Emergency timing matters, but unsafe cleanup can create more risk.
            Unstable trees, hanging limbs, and utility concerns should be treated
            carefully.
          </p>
        </article>
        <article>
          <span aria-hidden="true">02</span>
          <h3>Property protection</h3>
          <p>
            Access, roofs, fences, driveways, pools, and nearby structures all
            affect how tree work should be reviewed and discussed.
          </p>
        </article>
        <article>
          <span aria-hidden="true">03</span>
          <h3>Respect for local regulations</h3>
          <p>
            Florida tree rules are local and situation-specific. Permit and HOA
            questions should be checked before regulated work begins.
          </p>
        </article>
        <article>
          <span aria-hidden="true">04</span>
          <h3>Clear communication</h3>
          <p>
            Homeowners should understand what information is being requested,
            what may happen next, and that asking a question creates no
            obligation.
          </p>
        </article>
        <article>
          <span aria-hidden="true">05</span>
          <h3>Appropriate local matching</h3>
          <p>
            When a request is eligible, dispatch can help route it toward a
            local provider suited to the service type, location, and timing.
          </p>
        </article>
      </div>
    </section>

    <section class="expectations" aria-labelledby="expect-title">
      <div class="section-heading">
        <p>What homeowners can expect</p>
        <h2 id="expect-title">A clearer decision process</h2>
      </div>
      <div class="expect-grid">
        <article>
          <strong>Clear communication</strong>
          <span>Questions about timing, location, and service type are part of the review.</span>
        </article>
        <article>
          <strong>Honest recommendations</strong>
          <span>Some situations may need removal, while others may need pruning, monitoring, or documentation.</span>
        </article>
        <article>
          <strong>No obligation</strong>
          <span>You can request information or ask a tree safety question without committing to work.</span>
        </article>
        <article>
          <strong>Respect for property</strong>
          <span>Access limits, nearby structures, and site constraints should be discussed before work is considered.</span>
        </article>
        <article>
          <strong>Local considerations</strong>
          <span>County, city, HOA, storm, and species factors can all affect next steps.</span>
        </article>
      </div>
    </section>

    <section class="responsibility" aria-labelledby="responsibility-title">
      <div>
        <p class="eyebrow-dark">Insurance & responsibility</p>
        <h2 id="responsibility-title">What homeowners should verify</h2>
        <p>
          ProTreeTrim operates as a referral and dispatch network. Field work is
          performed by independent local providers, so homeowners should make
          informed decisions before authorizing work.
        </p>
      </div>
      <ul>
        <li>
          <strong>Insurance:</strong> Ask for current general liability and
          workers' compensation details when applicable.
        </li>
        <li>
          <strong>Licensing:</strong> Confirm any required local or trade
          licensing for the type of work being performed.
        </li>
        <li>
          <strong>Permits:</strong> Check city, county, HOA, or protected-tree
          requirements before regulated removal or pruning.
        </li>
        <li>
          <strong>Documentation:</strong> Keep photos, written estimates, and
          insurance communication when property damage or storm claims are involved.
        </li>
      </ul>
    </section>

    <section class="storm-response" aria-labelledby="storm-title">
      <div class="section-heading">
        <p>Storm response</p>
        <h2 id="storm-title">Emergency situations are not all the same</h2>
      </div>
      <p>
        Storm-damaged trees can shift after the weather passes. Limbs under
        tension, leaning trunks, saturated soil, and nearby utility lines can
        change the safest next step. Safety comes before cleanup speed.
      </p>
      <p>
        If the situation involves active electrical hazards, blocked emergency
        access, structural impact, or immediate danger, keep people away from the
        area and contact the appropriate utility or emergency authority when
        needed.
      </p>
    </section>

    <section class="questions" aria-labelledby="questions-title">
      <div class="section-heading">
        <p>Questions we encourage</p>
        <h2 id="questions-title">It is reasonable to ask before deciding</h2>
      </div>
      <div class="faq-list">
        {
          safetyQuestions.map((item) => (
            <article>
              <h3>{item.question}</h3>
              <p>{item.answer}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="why-exists" aria-labelledby="why-title">
      <h2 id="why-title">Why this page exists</h2>
      <p>
        This page is here to help homeowners understand the decision process
        before they request tree work. The goal is not to pressure anyone into
        hiring. The goal is to make the safety, responsibility, and communication
        expectations easier to understand.
      </p>
    </section>

    <section class="soft-cta" aria-labelledby="guidance-title">
      <h2 id="guidance-title">Have a tree safety question?</h2>
      <p>
        You can discuss the situation, ask what information to prepare, or
        request guidance on the next step.
      </p>
      <a
        href={SITE_CONFIG.phoneHref}
        aria-label={`Ask ProTreeTrim a tree safety question at ${SITE_CONFIG.phone}`}
      >
        Ask a Tree Safety Question: {SITE_CONFIG.phone}
      </a>
    </section>
  </main>
</MainLayout>

<style>
  .trust-hero {
    background: linear-gradient(135deg, #081c15 0%, #1b4332 100%);
    color: white;
    padding: 6rem 1.5rem;
    text-align: center;
  }

  .trust-hero h1 {
    font-size: clamp(2.15rem, 7vw, 3.75rem);
    font-weight: 900;
    line-height: var(--heading-line-height);
    margin: 0 auto;
    max-width: 920px;
    text-wrap: balance;
  }

  .trust-hero p:not(.eyebrow) {
    color: #c7f9d4;
    font-size: 1.18rem;
    line-height: 1.75;
    margin: 1.4rem auto 0;
    max-width: 820px;
  }

  .trust-main {
    max-width: 980px;
    padding: 5rem 1.5rem 10rem;
  }

  .eyebrow,
  .eyebrow-dark,
  .section-heading p {
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.65rem;
    text-transform: uppercase;
  }

  .eyebrow {
    color: #ffb703;
  }

  .eyebrow-dark,
  .section-heading p {
    color: #c2410c;
  }

  .section-heading {
    margin: 0 auto 1.8rem;
    max-width: 760px;
    text-align: center;
  }

  .section-heading h2,
  .responsibility h2,
  .why-exists h2,
  .soft-cta h2 {
    color: #064e3b;
    font-size: clamp(1.7rem, 4vw, 2.35rem);
    font-weight: 900;
    line-height: var(--heading-line-height);
    margin: 0;
    text-wrap: balance;
  }

  .principles,
  .expectations,
  .responsibility,
  .storm-response,
  .questions,
  .why-exists {
    margin-bottom: 5rem;
  }

  .principle-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
  }

  .principle-grid article,
  .expect-grid article,
  .faq-list article {
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: var(--radius-card);
    padding: var(--card-padding);
    box-shadow: var(--shadow-card);
  }

  .principle-grid span {
    color: #c2410c;
    display: block;
    font-size: 0.75rem;
    font-weight: 900;
    margin-bottom: 0.65rem;
  }

  h3 {
    color: #1b4332;
    font-size: 1.16rem;
    font-weight: 850;
    line-height: 1.35;
    margin: 0 0 0.55rem;
  }

  p,
  li,
  .expect-grid span {
    color: #4b5563;
    line-height: var(--reading-line-height);
  }

  p {
    margin: 0;
  }

  .expect-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  .expect-grid strong {
    color: #1b4332;
    display: block;
    margin-bottom: 0.45rem;
  }

  .expect-grid strong::before {
    color: #16a34a;
    content: "✓ ";
    font-weight: 900;
  }

  .responsibility {
    align-items: center;
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    display: grid;
    gap: 2rem;
    grid-template-columns: minmax(0, 0.9fr) minmax(0, 1.1fr);
    padding: 2rem;
  }

  .responsibility > div > p {
    margin-top: 1rem;
    max-width: 36rem;
  }

  .responsibility ul {
    display: grid;
    gap: 0.9rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .responsibility li {
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: 14px;
    box-shadow: var(--shadow-card);
    padding: 1rem;
  }

  .storm-response {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: var(--radius-panel);
    padding: 2rem;
  }

  .storm-response .section-heading {
    text-align: left;
    margin-left: 0;
  }

  .storm-response p + p {
    margin-top: 1rem;
  }

  .faq-list {
    display: grid;
    gap: 1rem;
  }

  .why-exists {
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-panel);
    padding: 2rem;
    text-align: center;
  }

  .why-exists p {
    margin: 1rem auto 0;
    max-width: 760px;
  }

  .soft-cta {
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: var(--radius-panel);
    box-shadow: var(--shadow-card);
    padding: 2.5rem;
    text-align: center;
  }

  .soft-cta p {
    margin: 1rem auto 1.6rem;
    max-width: 620px;
  }

  .soft-cta a {
    background: #ea580c;
    border-radius: 14px;
    color: white !important;
    display: inline-flex;
    font-size: 1.05rem;
    font-weight: 900;
    justify-content: center;
    min-height: 3.25rem;
    padding: 0.9rem 1.35rem;
    text-decoration: none;
  }

  .soft-cta a:focus {
    outline: 3px solid #ffb703;
    outline-offset: 3px;
  }

  .soft-cta a:hover {
    box-shadow: var(--shadow-cta);
  }

  @media (max-width: 760px) {
    .responsibility {
      grid-template-columns: 1fr;
    }

    .trust-hero {
      padding: 4.5rem 1.5rem;
    }

    .trust-main {
      padding: 4rem 1.2rem 10rem;
    }

    .principles,
    .expectations,
    .responsibility,
    .storm-response,
    .questions,
    .why-exists {
      margin-bottom: 4rem;
    }

    .responsibility,
    .storm-response,
    .why-exists,
    .soft-cta {
      padding: 1.4rem;
    }
  }
</style>
