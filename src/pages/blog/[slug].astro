---
import MainLayout from "../../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../../config.js";
import { getCollection } from "astro:content";
import { getBlogMoneyLinks } from "../../data/internal-links.js";
import BlogToolsCTA from "../../components/BlogToolsCTA.astro";

const slugifyCategory = (value) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-");

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));
const relatedPosts = allPosts
  .filter(
    (item) =>
      item.slug !== post.slug && item.data.category === post.data.category
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const canonicalUrl = `${SITE_CONFIG.siteUrl}/blog/${post.slug}/`;
const categoryUrl = `/blog/category/${slugifyCategory(post.data.category)}/`;
const moneyPageLinks = getBlogMoneyLinks({
  slug: post.slug,
  title: post.data.title,
  category: post.data.category,
  tags: post.data.tags || [],
});

const getDecisionTip = (category = "") => {
  const normalized = category.toLowerCase();

  switch (true) {
    case normalized.includes("storm") || normalized.includes("emergency"):
      return "Storm damage should be inspected before cleanup begins, especially when limbs are hanging, loaded, or near structures.";
    case normalized.includes("permit") || normalized.includes("law") || normalized.includes("regulation"):
      return "Permit rules can change by city, county, tree condition, and property type, so documentation matters before non-emergency removal.";
    case normalized.includes("stump") || normalized.includes("root"):
      return "Stump and root decisions should start with how the area will be used after cleanup, not just how low the stump can be ground.";
    case normalized.includes("palm"):
      return "Palm concerns are not always solved by heavier trimming; crown condition, timing, and species matter.";
    case normalized.includes("health") || normalized.includes("disease") || normalized.includes("pest"):
      return "Healthy-looking trees can still hide structural risk, decay, pests, or root problems that deserve a closer review.";
    case normalized.includes("removal"):
      return "Not every leaning or crowded tree requires removal, but visible defects, targets, and access should guide the decision.";
    default:
      return "A good tree decision usually starts with safety, site context, documentation, and the reason the work is being considered.";
  }
};

const decisionTip = getDecisionTip(post.data.category);
---

<MainLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonicalUrl}
  ogType="article"
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: post.data.title,
        description: post.data.description,
        datePublished: post.data.pubDate,
        dateModified: post.data.updatedDate ?? post.data.pubDate,
        author: {
          "@type": "Person",
          name: post.data.author,
        },
        publisher: {
          "@type": "Organization",
          name: "ProTreeTrim",
        },
        mainEntityOfPage: canonicalUrl,
      })}
    />
  </Fragment>

  <main class="container" style="max-width: 860px; padding: 4rem 1.5rem 10rem;">
    <a
      href="/blog/"
      style="display: inline-block; margin-bottom: 1.5rem; color: #166534; text-decoration: none; font-weight: 800;"
    >
      ← Back to blog
    </a>

    <article
      style="background: white; border: 1px solid #e5e7eb; border-radius: 28px; padding: 2rem 2rem 3rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
    >
      <div
        style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;"
      >
        <a
          href={categoryUrl}
          style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; text-decoration: none;"
        >
          {post.data.category}
        </a>
        <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
          Published{" "}
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </span>
        {
          post.data.updatedDate && (
            <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
              Updated{" "}
              {post.data.updatedDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          )
        }
      </div>

      <h1
        style="font-size: clamp(2rem, 5vw, 3.3rem); line-height: var(--heading-line-height); color: #1b4332; margin: 0 0 1rem; font-weight: 900;"
      >
        {post.data.title}
      </h1>

      <p style="font-size: 1.1rem; line-height: 1.75; color: #475569; margin-bottom: 2rem;">
        {post.data.description}
      </p>

      <div class="blog-prose">
        <Content />

        <BlogToolsCTA
          slug={post.slug}
          title={post.data.title}
          category={post.data.category}
          tags={post.data.tags || []}
        />
      </div>
    </article>

    <section class="blog-ending" aria-label="Recommended next steps">
      {
        relatedPosts.length > 0 && (
          <section class="ending-panel" aria-labelledby="continue-learning-title">
            <div class="ending-heading">
              <p>Related guides</p>
              <h2 id="continue-learning-title">Continue Learning</h2>
              <span>
                If you're still researching this topic, these related guides can help you understand your next decision.
              </span>
            </div>
            <div class="ending-card-grid">
              {relatedPosts.map((item) => (
                <a href={`/blog/${item.slug}/`} class="ending-card">
                  <small>
                    {item.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </small>
                  <strong>{item.data.title}</strong>
                </a>
              ))}
            </div>
            <a href={categoryUrl} class="ending-text-link">
              View all {post.data.category} guides →
            </a>
          </section>
        )
      }

      {
        moneyPageLinks.length > 0 && (
          <section class="ending-panel ending-panel--green" aria-labelledby="compare-options-title">
            <div class="ending-heading">
              <p>Service planning</p>
              <h2 id="compare-options-title">Compare Your Options</h2>
              <span>
                Some situations require trimming, others removal, emergency response, permits, or inspection.
              </span>
            </div>
            <div class="ending-card-grid ending-card-grid--service">
              {moneyPageLinks.map((link) => (
                <a href={link.href} class="ending-card ending-card--service">
                  <small>{link.eyebrow}</small>
                  <strong>{link.title}</strong>
                  <span>{link.reason}</span>
                </a>
              ))}
            </div>
          </section>
        )
      }

      <section class="ending-panel ending-panel--cta" aria-labelledby="local-guidance-title">
        <div class="ending-heading">
          <p>Local next step</p>
          <h2 id="local-guidance-title">Need Local Guidance?</h2>
          <span>
            If you're ready to discuss your situation with a local tree professional, explore available service areas.
          </span>
        </div>
        <div class="ending-actions" aria-label="Local guidance options">
          <a href="/">Explore Available Service Areas</a>
          <a href={SITE_CONFIG.phoneHref} aria-label={`Discuss your tree question with ProTreeTrim at ${SITE_CONFIG.phone}`}>
            Discuss Your Tree Question
          </a>
        </div>
      </section>

      <aside class="decision-tip" aria-labelledby="decision-tip-title">
        <p>Decision tip</p>
        <h2 id="decision-tip-title">Before you choose the next step</h2>
        <span>{decisionTip}</span>
      </aside>
    </section>
  </main>
</MainLayout>

<style>
  .blog-prose {
    color: #374151;
    font-size: 1.05rem;
    line-height: 1.78;
    max-width: var(--reading-width);
  }

  .blog-prose h2,
  .blog-prose h3 {
    color: #1b4332;
    line-height: var(--heading-line-height);
    margin-bottom: 0.75rem;
    font-weight: 900;
    text-wrap: balance;
  }

  .blog-prose h2 {
    font-size: 1.8rem;
    margin-top: 2rem;
  }

  .blog-prose h3 {
    font-size: 1.35rem;
    margin-top: 1.6rem;
  }

  .blog-prose p,
  .blog-prose ul,
  .blog-prose ol {
    margin: 0 0 1rem;
  }

  .blog-prose ul,
  .blog-prose ol {
    padding-left: 1.4rem;
  }

  .blog-prose li {
    margin-bottom: 0.45rem;
  }

  .blog-prose li > ul,
  .blog-prose li > ol {
    margin-top: 0.45rem;
  }

  .blog-prose table {
    border-collapse: collapse;
    display: block;
    line-height: 1.55;
    margin: 1.35rem 0;
    overflow-x: auto;
    width: 100%;
  }

  .blog-prose th,
  .blog-prose td {
    border: 1px solid #e5e7eb;
    padding: 0.8rem;
    vertical-align: top;
  }

  .blog-prose th {
    background: #f8fafc;
    color: #1b4332;
  }

  :global(.blog-prose a) {
    color: #166534;
    font-weight: 800;
    text-decoration-color: rgba(22, 101, 52, 0.35);
    text-decoration-thickness: 1px;
    text-underline-offset: 0.18em;
  }

  :global(.blog-prose a:hover) {
    color: #c2410c;
    text-decoration-color: currentColor;
  }

  :global(.blog-prose a:focus) {
    border-radius: 4px;
    outline: 3px solid #ffb703;
    outline-offset: 3px;
  }

  .blog-prose strong {
    color: #111827;
  }

  .blog-prose blockquote {
    margin: 1.35rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid #ea580c;
    background: #fff7ed;
    border-radius: 12px;
  }

  .blog-ending {
    display: grid;
    gap: 2rem;
    margin-top: 2rem;
  }

  .ending-panel,
  .decision-tip {
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: var(--radius-panel);
    box-shadow: var(--shadow-card);
    padding: clamp(1.4rem, 4vw, 2rem);
  }

  .ending-panel--green {
    background: #f0fdf4;
    border-color: #dcfce7;
  }

  .ending-panel--cta {
    background: #fff7ed;
    border-color: #fed7aa;
    text-align: center;
  }

  .ending-heading {
    margin-bottom: 1.2rem;
  }

  .ending-heading p,
  .decision-tip p {
    color: #c2410c;
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.55rem;
    text-transform: uppercase;
  }

  .ending-panel--green .ending-heading p {
    color: #166534;
  }

  .ending-heading h2,
  .decision-tip h2 {
    color: #1b4332;
    font-size: 1.5rem;
    font-weight: 900;
    line-height: var(--heading-line-height);
    margin: 0 0 0.45rem;
    text-wrap: balance;
  }

  .ending-heading span,
  .decision-tip span {
    color: #4b5563;
    display: block;
    line-height: 1.7;
  }

  .ending-card-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
  }

  .ending-card-grid--service {
    grid-template-columns: repeat(auto-fit, minmax(230px, 1fr));
  }

  .ending-card {
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    color: inherit;
    display: block;
    min-height: 100%;
    padding: 1.1rem;
    text-decoration: none;
  }

  .ending-card--service {
    border-color: #dcfce7;
  }

  .ending-card small {
    color: #94a3b8;
    display: block;
    font-size: 0.78rem;
    font-weight: 800;
    line-height: 1.4;
    margin-bottom: 0.55rem;
  }

  .ending-card--service small {
    color: #16a34a;
    font-size: 0.72rem;
    font-weight: 900;
    text-transform: uppercase;
  }

  .ending-card strong {
    color: #1b4332;
    display: block;
    font-weight: 900;
    line-height: 1.35;
  }

  .ending-card span {
    color: #64748b;
    display: block;
    font-size: 0.85rem;
    line-height: 1.5;
    margin-top: 0.45rem;
  }

  .ending-text-link {
    color: #ea580c;
    display: inline-flex;
    font-weight: 900;
    margin-top: 1rem;
    text-decoration: none;
  }

  .ending-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    justify-content: center;
    margin-top: 1.4rem;
  }

  .ending-actions a {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.1rem;
    text-decoration: none;
  }

  .ending-actions a:first-child {
    background: #1b4332;
    color: white;
  }

  .ending-actions a:last-child {
    background: #ea580c;
    color: white;
    box-shadow: var(--shadow-cta);
  }

  .decision-tip {
    background: #fffbeb;
    border-color: #fef3c7;
  }

  .decision-tip p {
    color: #b45309;
  }

  .decision-tip h2 {
    color: #92400e;
  }

  .decision-tip span {
    color: #78350f;
    font-weight: 700;
  }

  .ending-card:focus,
  .ending-text-link:focus,
  .ending-actions a:focus {
    outline: 3px solid #ffb703;
    outline-offset: 3px;
  }

  .ending-card:hover {
    border-color: #ea580c;
    box-shadow: var(--shadow-card-hover);
  }

  @media (max-width: 640px) {
    main.container {
      padding: 3rem 1.2rem 9rem !important;
    }

    article {
      border-radius: var(--radius-panel) !important;
      padding: 1.4rem !important;
    }

    article h1 {
      line-height: var(--mobile-heading-line-height) !important;
    }

    .blog-prose {
      font-size: 1rem;
      line-height: 1.72;
    }

    .blog-prose h2 {
      margin-top: 1.7rem;
    }

    .blog-prose h3 {
      margin-top: 1.35rem;
    }

    .ending-actions {
      display: grid;
    }
  }
</style>
