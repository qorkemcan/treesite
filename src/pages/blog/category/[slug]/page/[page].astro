---
import MainLayout from "../../../../../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../../../../../config.js";
import { getCollection } from "astro:content";

const normalizeCategory = (value: string) => {
  const clean = value.trim().replace(/\s+/g, " ");

  const aliases: Record<string, string> = {
    "emergency storm": "Emergency & Storm",
    "emergency & storm": "Emergency & Storm",
    "florida laws & property risk": "Florida Laws & Property Risk",
    "tree care & cleanup": "Tree Care & Cleanup",
    "tree health & disease": "Tree Health & Disease",
    "landscaping & planting": "Landscaping & Planting",
    "local florida guides": "Local Florida Guides",
    "tree removal": "Tree Removal",
  };

  return aliases[clean.toLowerCase()] ?? clean;
};

const slugifyCategory = (value: string) =>
  normalizeCategory(value)
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-");

export async function getStaticPaths() {
  const POSTS_PER_PAGE = 12;

  const localNormalizeCategory = (value: string) => {
    const clean = value.trim().replace(/\s+/g, " ");

    const aliases: Record<string, string> = {
      "emergency storm": "Emergency & Storm",
      "emergency & storm": "Emergency & Storm",
      "florida laws & property risk": "Florida Laws & Property Risk",
      "tree care & cleanup": "Tree Care & Cleanup",
      "tree health & disease": "Tree Health & Disease",
      "landscaping & planting": "Landscaping & Planting",
      "local florida guides": "Local Florida Guides",
      "tree removal": "Tree Removal",
    };

    return aliases[clean.toLowerCase()] ?? clean;
  };

  const localSlugifyCategory = (value: string) =>
    localNormalizeCategory(value)
      .toLowerCase()
      .trim()
      .replace(/&/g, "and")
      .replace(/[^a-z0-9\s-]/g, "")
      .replace(/\s+/g, "-");

  const posts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));

  const categoryMap = new Map<string, { name: string; posts: typeof posts }>();
  posts.forEach((post) => {
    const category = localNormalizeCategory(post.data.category);
    if (!category) return;

    const slug = localSlugifyCategory(category);
    if (!categoryMap.has(slug)) {
      categoryMap.set(slug, { name: category, posts: [] });
    }
    categoryMap.get(slug)?.posts.push(post);
  });

  const paths = [];

  for (const [categorySlug, group] of categoryMap.entries()) {
    const categoryPosts = group.posts
      .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

    const totalPages = Math.ceil(categoryPosts.length / POSTS_PER_PAGE);

    for (let page = 2; page <= totalPages; page++) {
      paths.push({
        params: {
          slug: categorySlug,
          page: String(page),
        },
      });
    }
  }

  return paths;
}

const POSTS_PER_PAGE = 12;

const allPosts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));

const categoryMap = new Map<string, { name: string; posts: typeof allPosts }>();
allPosts.forEach((post) => {
  const category = normalizeCategory(post.data.category);
  if (!category) return;

  const slug = slugifyCategory(category);
  if (!categoryMap.has(slug)) {
    categoryMap.set(slug, { name: category, posts: [] });
  }
  categoryMap.get(slug)?.posts.push(post);
});

const currentCategorySlug = Astro.params.slug ?? "";
const currentPage = Number(Astro.params.page);

const categoryGroup = categoryMap.get(currentCategorySlug);
const categoryName = categoryGroup?.name;

if (!categoryName) {
  throw new Error(`Invalid category slug: ${currentCategorySlug}`);
}

const categoryPosts = (categoryGroup?.posts ?? [])
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const totalPosts = categoryPosts.length;
const totalPages = Math.ceil(totalPosts / POSTS_PER_PAGE);

if (
  !Number.isInteger(currentPage) ||
  currentPage < 2 ||
  currentPage > totalPages
) {
  throw new Error(`Invalid category page number: ${Astro.params.page}`);
}

const startIndex = (currentPage - 1) * POSTS_PER_PAGE;
const endIndex = startIndex + POSTS_PER_PAGE;
const posts = categoryPosts.slice(startIndex, endIndex);

const startPost = startIndex + 1;
const endPost = Math.min(endIndex, totalPosts);

const pageTitle = `${categoryName} Articles - Page ${currentPage} | ProTreeTrim Blog`;
const pageDescription = `Read ${categoryName.toLowerCase()} articles from the ProTreeTrim blog.`;
const canonicalUrl = `${SITE_CONFIG.siteUrl}/blog/category/${currentCategorySlug}/page/${currentPage}/`;
---

<MainLayout
  title={pageTitle}
  description={pageDescription}
  canonical={canonicalUrl}
>
  <Fragment slot="head">
    <link
      rel="prev"
      href={currentPage - 1 === 1
        ? `${SITE_CONFIG.siteUrl}/blog/category/${currentCategorySlug}/`
        : `${SITE_CONFIG.siteUrl}/blog/category/${currentCategorySlug}/page/${currentPage - 1}/`}
    />
    {
      currentPage < totalPages && (
        <link
          rel="next"
          href={`${SITE_CONFIG.siteUrl}/blog/category/${currentCategorySlug}/page/${currentPage + 1}/`}
        />
      )
    }
  </Fragment>

  <header
    style="background: linear-gradient(135deg, #1b4332 0%, #081c15 100%); color: white; padding: 4.5rem 1.5rem; text-align: center; border-bottom: 5px solid #ea580c;"
  >
    <div class="container">
      <div
        style="font-size: 0.85rem; margin-bottom: 1rem; color: #ffb703; font-weight: 800; text-transform: uppercase;"
      >
        Blog Category Archive
      </div>
      <h1
        style="font-size: clamp(2.2rem, 6vw, 3.6rem); margin: 0; font-weight: 900; line-height: var(--heading-line-height); text-wrap: balance;"
      >
        {categoryName}
      </h1>
      <p
        style="font-size: 1.05rem; color: #95d5b2; line-height: var(--reading-line-height); margin-top: 1rem; max-width: 760px; margin-left: auto; margin-right: auto;"
      >
        Page {currentPage} of {totalPages}. Browse all posts filed under {
          categoryName
        }.
      </p>
    </div>
  </header>

  <main
    class="container"
    style="padding: 3rem 1.5rem 10rem; max-width: 1100px;"
  >
    <div style="margin-bottom: 1.75rem;">
      <a
        href="/blog/"
        style="display: inline-block; color: #166534; text-decoration: none; font-weight: 800;"
      >
        ← Back to all blog posts
      </a>
    </div>

    <div
      style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.25rem 1.5rem; margin-bottom: 1.5rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
    >
      <strong style="color: #1b4332;">{startPost}-{endPost}</strong>
      <span style="color: #64748b;">
        of {totalPosts} article(s) in this category</span
      >
    </div>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(320px, 1fr)); gap: 24px;"
    >
      {
        posts.map((post) => (
          <article style="background: white; border: 1px solid #e5e7eb; border-radius: 24px; padding: 1.75rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);">
            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;">
              <span style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">
                {normalizeCategory(post.data.category)}
              </span>
              <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </span>
            </div>

            <h2 style="margin: 0 0 0.7rem; font-size: 1.55rem; line-height: var(--heading-line-height); text-wrap: balance;">
              <a
                href={`/blog/${post.slug}/`}
                style="color: #1b4332; text-decoration: none; font-weight: 900;"
              >
                {post.data.title}
              </a>
            </h2>

            <p style="color: #475569; line-height: var(--reading-line-height); margin-bottom: 1.2rem;">
              {post.data.description}
            </p>

            <a
              href={`/blog/${post.slug}/`}
              style="display: inline-block; background: #ea580c; color: white; text-decoration: none; padding: 12px 18px; border-radius: 12px; font-weight: 800;"
            >
              Read article
            </a>
          </article>
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav
          aria-label={`${categoryName} pagination`}
          style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 2.25rem;"
        >
          <a
            href={
              currentPage - 1 === 1
                ? `/blog/category/${currentCategorySlug}/`
                : `/blog/category/${currentCategorySlug}/page/${currentPage - 1}/`
            }
            style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
          >
            ← Prev
          </a>

          {Array.from({ length: totalPages }, (_, index) => index + 1).map(
            (page) =>
              page === currentPage ? (
                <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; background: #1b4332; color: white; font-weight: 900;">
                  {page}
                </span>
              ) : (
                <a
                  href={
                    page === 1
                      ? `/blog/category/${currentCategorySlug}/`
                      : `/blog/category/${currentCategorySlug}/page/${page}/`
                  }
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
                >
                  {page}
                </a>
              ),
          )}

          {currentPage < totalPages ? (
            <a
              href={`/blog/category/${currentCategorySlug}/page/${currentPage + 1}/`}
              style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
            >
              Next →
            </a>
          ) : (
            <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #94a3b8; font-weight: 800;">
              Next →
            </span>
          )}
        </nav>
      )
    }
  </main>
</MainLayout>

<style>
  main.container article {
    border: var(--border-soft) !important;
    border-radius: var(--radius-card) !important;
    box-shadow: var(--shadow-card) !important;
  }

  main.container article:hover {
    border-color: #ea580c !important;
    box-shadow: var(--shadow-card-hover) !important;
  }

  main.container article > a:last-child {
    box-shadow: var(--shadow-cta);
  }

  main.container nav a,
  main.container nav span {
    border-radius: 12px !important;
  }
</style>
