    </div>

    <div class="article-grid">
      {
        posts.map((post) => (
          <article class="article-card">
            <div style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;">
              <span style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase;">
                {normalizeCategory(post.data.category)}
              </span>
              <small>
                {post.data.pubDate.toLocaleDateString("en-US", {
                  year: "numeric",
                  month: "long",
                  day: "numeric",
                })}
              </small>
            </div>

            <h3>
              <a href={`/blog/${post.slug}/`}>{post.data.title}</a>
            </h3>

            <p>{post.data.description}</p>

            <a
              href={`/blog/${post.slug}/`}
              class="read-link"
            >
              Read article
            </a>
          </article>
        ))
      }
    </div>

    {
      totalPages > 1 && (
        <nav
          class="blog-pagination-nav"
          aria-label={`${categoryName} pagination`}
          style="display: flex; flex-wrap: wrap; gap: 10px; justify-content: center; margin-top: 2.25rem;"
        >
          <span style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: #f8fafc; color: #94a3b8; font-weight: 800;">
            ← Prev
          </span>

          <span
            class="blog-pagination-mobile-summary"
            style="display: none; align-items: center; justify-content: center; min-width: 132px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; font-weight: 900;"
          >
            Page {currentPage} of {totalPages}
          </span>

          {paginationItems.map((item, index) =>
              item === "ellipsis" ? (
                <span
                  class="blog-pagination-ellipsis"
                  aria-hidden="true"
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 34px; height: 46px; color: #94a3b8; font-weight: 900;"
                >
                  …
                </span>
              ) : item === currentPage ? (
                <span
                  class="blog-pagination-page"
                  aria-current="page"
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; background: #1b4332; color: white; font-weight: 900;"
                >
                  {item}
                </span>
              ) : (
                <a
                  class="blog-pagination-page"
                  href={item === 1 ? `/blog/category/${categorySlug}/` : `/blog/category/${categorySlug}/page/${item}/`}
                  style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
                >
                  {item}
                </a>
              ),
            )}

          <a
            href={`/blog/category/${categorySlug}/page/2/`}
            style="display: inline-flex; align-items: center; justify-content: center; min-width: 46px; height: 46px; padding: 0 16px; border-radius: 12px; border: 1px solid #e2e8f0; background: white; color: #1b4332; text-decoration: none; font-weight: 800;"
          >
            Next →
          </a>
        </nav>
      )
    }
  </main>
</MainLayout>
