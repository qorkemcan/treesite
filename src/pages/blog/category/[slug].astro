      background: white;
      border: 1px solid #e5e7eb;
      border-radius: 18px;
      color: inherit;
      display: block;
      min-height: 100%;
      padding: 1.25rem;
      text-decoration: none;
    }

    .start-card small,
    .article-card small {
      color: #94a3b8;
      display: block;
      font-size: 0.8rem;
      font-weight: 800;
      margin-bottom: 0.6rem;
    }

    .start-card strong,
    .article-card h3 {
      color: #1b4332;
      display: block;
      font-size: 1.08rem;
      font-weight: 900;
      line-height: 1.35;
      margin: 0;
    }

    .start-card span,
    .article-card p {
      color: #526253;
      display: block;
      line-height: 1.65;
      margin: 0.75rem 0 0;
    }

    .decision-path {
      background: #fff7ed;
      border: 1px solid #fed7aa;
      border-radius: 24px;
      padding: 1.75rem;
    }

    .decision-path p {
      color: #c2410c;
    }

    .decision-steps {
      display: grid;
      gap: 1rem;
      grid-template-columns: repeat(3, minmax(0, 1fr));
      list-style: none;
      margin: 1.5rem 0 0;
      padding: 0;
    }

    .decision-steps li {
      background: white;
      border: 1px solid #fed7aa;
      border-radius: 16px;
      color: #7c2d12;
      font-weight: 900;
      padding: 1rem;
      position: relative;
    }

    .decision-steps li:not(:last-child)::after {
      color: #c2410c;
      content: "→";
      font-weight: 900;
      position: absolute;
      right: -0.75rem;
      top: 50%;
      transform: translateY(-50%);
    }

    .next-step-grid {
      grid-template-columns: repeat(3, minmax(0, 1fr));
    }

    .next-step-card {
