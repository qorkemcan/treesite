};

const categoryProfile =
  categoryProfiles[categorySlug] || fallbackCategoryProfile;
const startHerePosts = posts.slice(0, 3);

const pageTitle = `${categoryName} Guides for Florida Homeowners`;
const pageDescription = categoryProfile.description;
const canonicalUrl = `${SITE_CONFIG.siteUrl}/blog/category/${categorySlug}/`;

const startPost = totalPosts === 0 ? 0 : 1;
const endPost = Math.min(posts.length, totalPosts);

type PaginationItem = number | "ellipsis";

const getCompactPaginationItems = (
  currentPage: number,
  totalPages: number,
): PaginationItem[] => {
  const pageNumbers = new Set<number>([1, totalPages, currentPage]);

  if (currentPage <= 2) {
    pageNumbers.add(2);
    pageNumbers.add(3);
  } else if (currentPage >= totalPages - 1) {
    pageNumbers.add(totalPages - 2);
    pageNumbers.add(totalPages - 1);
  } else {
    pageNumbers.add(currentPage - 1);
    pageNumbers.add(currentPage + 1);
  }

  const sortedPages = [...pageNumbers]
    .filter((page) => page >= 1 && page <= totalPages)
    .sort((a, b) => a - b);

  return sortedPages.reduce<PaginationItem[]>((items, page, index) => {
    const previousPage = sortedPages[index - 1];

    if (previousPage && page - previousPage > 1) {
      items.push("ellipsis");
    }

    items.push(page);
    return items;
  }, []);
};

const paginationItems = getCompactPaginationItems(currentPage, totalPages);
---

<MainLayout
