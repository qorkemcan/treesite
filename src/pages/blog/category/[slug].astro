  path: ["Learn the issue", "Compare your options", "Find local guidance when needed"] as [string, string, string],
  nextSteps: [
    { label: "Tree Care Advisor", href: "/tools/florida-tree-care-advisor/" },
    { label: "Trust & Safety", href: "/trust-safety/" },
    { label: "Contact Dispatch", href: "/contact/" },
