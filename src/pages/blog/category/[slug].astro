  </header>

  <main class="container category-main">
    <a href="/blog/" class="back-link">← Back to all blog posts</a>

    {
      startHerePosts.length > 0 && (
        <section class="section-block" aria-labelledby="start-here-title">
          <div class="section-heading">
            <p>Start Here</p>
            <h2 id="start-here-title">Good places to begin</h2>
            <span>If you're new to this topic, these guides are a good place to begin.</span>
          </div>

          <div class="start-grid">
            {startHerePosts.map((post) => (
              <a href={`/blog/${post.slug}/`} class="start-card">
                <small>
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
