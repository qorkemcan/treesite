    .next-step-card:focus,
    .article-card h3 a:focus,
    .read-link:focus,
    .blog-pagination-page:focus,
    .blog-pagination-next:focus {
      outline: 3px solid #ffb703;
      outline-offset: 3px;
    }

    @media (max-width: 800px) {
      .start-grid,
      .next-step-grid,
      .article-list-heading,
      .decision-steps {
