                <strong>{post.data.title}</strong>
                <span>{post.data.description}</span>
              </a>
            ))}
          </div>
        </section>
      )
    }

    <section class="section-block decision-path" aria-labelledby="decision-path-title">
      <p>Category decision path</p>
      <h2 id="decision-path-title">How this topic supports the next decision</h2>
      <span>{categoryProfile.decisionFocus}</span>
      <ol class="decision-steps">
        {categoryProfile.path.map((step) => <li>{step}</li>)}
      </ol>
    </section>

    <section class="section-block" aria-labelledby="next-steps-title">
      <div class="section-heading">
        <p>Related next steps</p>
        <h2 id="next-steps-title">Where homeowners often go next</h2>
        <span>Use these existing resources when this category raises a service, safety, permit, or local guidance question.</span>
      </div>
      <div class="next-step-grid">
        {categoryProfile.nextSteps.map((step) => (
          <a href={step.href} class="next-step-card">
            <span>Next step</span>
            <strong>{step.label}</strong>
