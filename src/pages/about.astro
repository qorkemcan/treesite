---
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config.js";
import { Image } from "astro:assets";
import teamImg from "../assets/team.jpg";

const workSteps = [
  {
    title: "Learn",
    text: "Start with practical resources about the tree, property, storm, permit, or safety concern.",
  },
  {
    title: "Understand",
    text: "Review what may affect the decision, including access, risk, species, timing, and local rules.",
  },
  {
    title: "Compare",
    text: "Look at possible next steps before deciding whether pruning, removal, documentation, or monitoring makes sense.",
  },
  {
    title: "Request Local Help",
    text: "When appropriate, ProTreeTrim can help route eligible requests toward a local provider.",
  },
];

const resourceTypes = [
  "Storm guidance",
  "Palm care",
  "Oak guidance",
  "Permit information",
  "Hiring advice",
  "Emergency resources",
  "Decision guides",
  "Root and stump questions",
];

const principles = [
  "Knowledge reduces costly mistakes.",
  "Safety comes before speed.",
  "Homeowners deserve clear information.",
  "Good decisions happen before hiring.",
];
---

<MainLayout
  title="About ProTreeTrim Homeowner Guidance"
  description="Learn how ProTreeTrim helps Florida homeowners understand tree care decisions, educational resources, local considerations, and provider connection options."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "AboutPage",
        name: "About ProTreeTrim Homeowner Guidance",
        description:
          "Information about how ProTreeTrim helps Florida homeowners understand tree care decisions before requesting local assistance.",
        url: `${SITE_CONFIG.siteUrl}/about/`,
        mainEntity: {
          "@type": "Organization",
          name: SITE_CONFIG.brandName,
          telephone: SITE_CONFIG.phoneHref.replace("tel:", ""),
          email: SITE_CONFIG.email,
          areaServed: {
            "@type": "State",
            name: "Florida",
          },
        },
      })}
    />
  </Fragment>

  <header class="about-hero">
    <div class="container">
      <p class="eyebrow">About ProTreeTrim</p>
      <h1>Helping Homeowners Make Better Tree Decisions Across Florida</h1>
      <p>
        ProTreeTrim exists to help homeowners understand tree care decisions
        before choosing local assistance. The site organizes practical Florida
        guidance around storms, palms, oaks, permits, removal questions, and
        property safety.
      </p>
    </div>
  </header>

  <main class="container about-main">
    <section class="intro-grid" aria-labelledby="mission-title">
      <div>
        <p class="eyebrow-dark">Our mission</p>
        <h2 id="mission-title">Education before sales</h2>
        <p>
          Many tree decisions are easier to make when the homeowner understands
          the context first. Our mission is to make that context clearer: what
          may be risky, what may need documentation, what may require local
          review, and what questions are worth asking before a quote.
        </p>
        <p>
          ProTreeTrim is built around clear information before pressure. Some
          visitors need a local provider. Others simply need to understand what
          they are seeing in the yard. Both starting points matter.
        </p>
      </div>
      <figure>
        <Image
          src={teamImg}
          alt="Florida tree service coordination and homeowner guidance"
          width={720}
          height={480}
        />
        <figcaption>
          Practical guidance, local context, and provider connection when it is
          appropriate.
        </figcaption>
      </figure>
    </section>

    <section class="work-flow" aria-labelledby="works-title">
      <div class="section-heading">
        <p>How ProTreeTrim works</p>
        <h2 id="works-title">A simple path from question to next step</h2>
      </div>
      <ol>
        {
          workSteps.map((step) => (
            <li>
              <span>{step.title}</span>
              <p>{step.text}</p>
            </li>
          ))
        }
      </ol>
    </section>

    <section class="why-built" aria-labelledby="built-title">
      <div>
        <p class="eyebrow-dark">Why we built this site</p>
        <h2 id="built-title">Tree problems are occasional, but the decisions can be expensive</h2>
      </div>
      <p>
        Most homeowners do not think about tree risk, pruning standards, permit
        questions, palm decline, storm damage, or root conflicts every week.
        When a problem does appear, reliable information can feel scattered or
        too technical.
      </p>
      <p>
        This site was created to organize practical guidance in one place so
        homeowners can slow down, understand the situation, and decide what kind
        of help may be useful.
      </p>
    </section>

    <section class="resources" aria-labelledby="find-title">
      <div class="section-heading">
        <p>What you'll find here</p>
        <h2 id="find-title">Guides organized around real homeowner questions</h2>
      </div>
      <div class="resource-grid">
        {
          resourceTypes.map((item) => (
            <article>
              <strong>{item}</strong>
            </article>
          ))
        }
      </div>
    </section>

    <section class="beliefs" aria-labelledby="belief-title">
      <div class="section-heading">
        <p>What we believe</p>
        <h2 id="belief-title">Better information leads to better decisions</h2>
      </div>
      <div class="belief-grid">
        {
          principles.map((item) => (
            <article>
              <p>{item}</p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="transparency" aria-labelledby="transparency-title">
      <div>
        <p class="eyebrow-dark">Transparency</p>
        <h2 id="transparency-title">Education is the primary purpose</h2>
        <p>
          ProTreeTrim publishes homeowner education and local tree care guidance.
          When appropriate, the platform can also connect homeowners with local
          providers for service requests.
        </p>
        <p>
          Field work is performed by independent providers. Homeowners should
          ask questions, verify requirements, and make informed decisions before
          authorizing tree work.
        </p>
      </div>
      <div class="transparency-links" aria-label="Related trust resources">
        <a href="/trust-safety/">Read Trust & Safety</a>
        <a href="/contact/">Discuss Your Tree Question</a>
      </div>
    </section>

    <section class="soft-cta" aria-labelledby="cta-title">
      <h2 id="cta-title">Start with the question in front of you</h2>
      <p>
        Explore Florida tree resources, or contact dispatch if you need help
        understanding a specific situation.
      </p>
      <div class="cta-actions">
        <a href="/blog/">Explore Florida Tree Resources</a>
        <a href={SITE_CONFIG.phoneHref} aria-label={`Discuss your tree question with ProTreeTrim at ${SITE_CONFIG.phone}`}>
          Discuss Your Tree Question
        </a>
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .about-hero {
    background: linear-gradient(135deg, #1b4332 0%, #081c15 100%);
    color: white;
    padding: 5.5rem 1.5rem;
    text-align: center;
  }

  .about-hero h1 {
    font-size: clamp(2.25rem, 7vw, 3.85rem);
    font-weight: 900;
    line-height: var(--heading-line-height);
    margin: 0 auto;
    max-width: 940px;
    text-wrap: balance;
  }

  .about-hero p:not(.eyebrow) {
    color: #c7f9d4;
    font-size: 1.16rem;
    line-height: 1.75;
    margin: 1.35rem auto 0;
    max-width: 820px;
  }

  .about-main {
    max-width: 1040px;
    padding: 5rem 1.5rem 10rem;
  }

  .eyebrow,
  .eyebrow-dark,
  .section-heading p {
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.65rem;
    text-transform: uppercase;
  }

  .eyebrow {
    color: #ffb703;
  }

  .eyebrow-dark,
  .section-heading p {
    color: #c2410c;
  }

  .intro-grid,
  .transparency {
    align-items: start;
    display: grid;
    gap: 3rem;
    grid-template-columns: minmax(0, 1fr) minmax(300px, 0.85fr);
    margin-bottom: 5rem;
  }

  .intro-grid h2,
  .why-built h2,
  .transparency h2,
  .section-heading h2,
  .soft-cta h2 {
    color: #064e3b;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 900;
    line-height: var(--heading-line-height);
    margin: 0;
    text-wrap: balance;
  }

  .intro-grid p,
  .why-built p,
  .transparency p,
  .soft-cta p,
  .work-flow li p {
    color: #4b5563;
    line-height: var(--reading-line-height);
    margin: 1rem 0 0;
  }

  figure {
    margin: 0;
  }

  figure img {
    border-radius: var(--radius-panel);
    box-shadow: 0 20px 40px rgba(15, 23, 42, 0.12);
    display: block;
    height: auto;
    width: 100%;
  }

  figcaption {
    color: #64748b;
    font-size: 0.9rem;
    line-height: 1.6;
    margin-top: 0.8rem;
    text-align: center;
  }

  .section-heading {
    margin: 0 auto 2rem;
    max-width: 780px;
    text-align: center;
  }

  .work-flow,
  .why-built,
  .resources,
  .beliefs,
  .transparency {
    margin-bottom: 5rem;
  }

  .work-flow ol {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .work-flow li {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-card);
    padding: 1.35rem;
    position: relative;
  }

  .work-flow li:not(:last-child)::after {
    color: #94a3b8;
    content: "→";
    font-weight: 900;
    position: absolute;
    right: -0.85rem;
    top: 50%;
    transform: translateY(-50%);
  }

  .work-flow span {
    color: #1b4332;
    display: block;
    font-size: 1.05rem;
    font-weight: 900;
  }

  .why-built {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    padding: 2rem;
  }

  .resource-grid,
  .belief-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .resource-grid article,
  .belief-grid article {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-card);
    padding: 1.25rem;
  }

  .resource-grid strong {
    color: #1b4332;
    display: block;
    line-height: 1.35;
  }

  .belief-grid p {
    color: #166534;
    font-weight: 800;
    line-height: 1.55;
    margin: 0;
  }

  .belief-grid p::before {
    color: #16a34a;
    content: "✓ ";
    font-weight: 900;
  }

  .transparency {
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-panel);
    padding: 2rem;
  }

  .transparency-links,
  .cta-actions {
    display: grid;
    gap: 0.75rem;
  }

  .transparency-links a,
  .cta-actions a {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.1rem;
    text-decoration: none;
  }

  .transparency-links a {
    background: white;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .soft-cta {
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    padding: 2.5rem;
    text-align: center;
  }

  .soft-cta p {
    margin: 1rem auto 1.7rem;
    max-width: 700px;
  }

  .cta-actions {
    grid-template-columns: repeat(2, max-content);
    justify-content: center;
  }

  .cta-actions a:first-child {
    background: #1b4332;
    color: white;
  }

  .cta-actions a:last-child {
    background: #ea580c;
    color: white;
  }

  a:focus {
    outline: 3px solid #ffb703;
    outline-offset: 3px;
  }

  .transparency-links a:hover,
  .cta-actions a:hover {
    transform: translateY(-1px);
  }

  @media (max-width: 900px) {
    .intro-grid,
    .transparency,
    .work-flow ol,
    .resource-grid,
    .belief-grid {
      grid-template-columns: 1fr;
    }

    .work-flow li:not(:last-child)::after {
      bottom: -1.15rem;
      content: "↓";
      left: 50%;
      right: auto;
      top: auto;
      transform: translateX(-50%);
    }

    .cta-actions {
      grid-template-columns: 1fr;
    }

    .about-hero {
      padding: 4.5rem 1.2rem;
    }

    .about-main {
      padding: 4rem 1.2rem 10rem;
    }

    .work-flow,
    .why-built,
    .resources,
    .beliefs,
    .transparency {
      margin-bottom: 4rem;
    }

    .why-built,
    .transparency,
    .soft-cta {
      padding: 1.4rem;
    }
  }
</style>
