---
import fs from "node:fs";
import path from "node:path";
import { parse } from "csv-parse/sync";
import MainLayout from "../../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../../config.js";
import { getCountyGuideLinks, getCountyMoneyLinkGroups } from "../../data/internal-links.js";
import countyPermitData from "../../data/county-permits.json";
import AudioGuideBlock from "../../components/AudioGuideBlock.astro";
import { cityServicePath, countySlug as makeCountySlug } from "../../lib/slugs.js";

export async function getStaticPaths() {
  const filePath = path.resolve("./src/data/cities.csv");
  const fileContent = fs.readFileSync(filePath, "utf-8");
  const records = parse(fileContent, {
    columns: true,
    skip_empty_lines: true,
    bom: true,
  });

  const counties = [...new Set(records.map((r) => r.County))];

  return counties.map((county) => {
    const countySlug = makeCountySlug(county);
    const citiesInCounty = records.filter((r) => r.County === county);

    return {
      params: { county: countySlug },
      props: {
        countyName: county,
        cities: citiesInCounty,
      },
    };
  });
}

const { countyName, cities } = Astro.props;
const displayCounty = countyName + " County";
const countySlug = makeCountySlug(countyName);
const countyCanonicalUrl = `${SITE_CONFIG.siteUrl}/county/${countySlug}/`;

// SEO İÇİN GÜNCEL TARİH VE İSTATİSTİK
const currentYear = new Date().getFullYear();
const currentMonth = new Date().toLocaleString("en-US", { month: "long" });
const cityCount = cities.length;

const toTitleCase = (str) => {
  if (!str) return "";
  return str
    .toLowerCase()
    .split(" ")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

// İLÇE ÖZELİNDE TEKNİK NOT OLUŞTURUCU (ÖZGÜNLEŞTİRİCİ)
const primaryCountyTree = cities[0]?.MainTreeType || "native Florida trees";
const countyClimateNote = `As of ${currentMonth} ${currentYear}, local provider coordination in ${displayCounty} often focuses on storm preparation, safe access, cleanup planning, and mature ${primaryCountyTree} concerns across ${cityCount} service zones.`;
const countyMoneyGroups = getCountyMoneyLinkGroups(countyName, cities);
const countyGuideLinks = getCountyGuideLinks(countyName);
const countyPermit = countyPermitData[countySlug] || countyPermitData.fallback;
---

<MainLayout
  title={`Tree Removal & Services in ${displayCounty}, FL | ${currentYear} Local Guide`}
  description={`Professional tree service dispatch and estimate coordination across ${cityCount} cities in ${displayCounty}, including tree removal, stump grinding, and emergency response planning.`}
  canonical={countyCanonicalUrl}
  weatherCounty={countyName}
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ItemList",
        name: `Top Rated Tree Services in ${displayCounty}`,
        description: `Comprehensive directory of tree care specialists serving ${displayCounty}, Florida.`,
        itemListElement: cities.slice(0, 20).map((city, index) => {
          return {
            "@type": "ListItem",
            position: index + 1,
            url: `${SITE_CONFIG.siteUrl}${cityServicePath("tree-removal", city.City, city.County)}`,
            name: `Tree Removal in ${city.City}`,
          };
        }),
      })}
    />
  </Fragment>

  <header
    style="background: linear-gradient(135deg, #1b4332 0%, #081c15 100%); color: white; padding: 5rem 1.5rem; text-align: center; border-bottom: 5px solid #ea580c;"
  >
    <div class="container">
      <div
        style="font-size: 0.85rem; margin-bottom: 1rem; color: #ffb703; font-weight: 800; text-transform: uppercase;"
      >
        Florida Tree Service Dispatch Network • {displayCounty}
      </div>
      <h1
        style="font-size: clamp(2.2rem, 7vw, 3.5rem); margin: 0; font-weight: 900; line-height: var(--heading-line-height);"
      >
        {displayCounty} Tree Experts
      </h1>
      <p
        style="font-size: 1.2rem; color: #95d5b2; margin-top: 1rem; max-width: 800px; margin-left: auto; margin-right: auto;"
      >
        Helping property owners compare local tree removal, stump grinding, and emergency response options across <strong
          >{cityCount} service zones</strong
        > in the {countyName} region.
      </p>
    </div>
  </header>

  <nav
    style="background: #f8fafc; padding: 12px 0; border-bottom: 1px solid #e2e8f0;"
  >
    <div class="container">
      <div
        style="font-size: 0.8rem; font-weight: 700; color: #64748b; text-transform: uppercase;"
      >
        <a href="/" style="color: #1b4332; text-decoration: none;">Home</a> /
        <span style="color: #94a3b8;">Florida</span> /
        <span style="color: #ea580c;">{displayCounty} Hub</span>
      </div>
    </div>
  </nav>

  <main class="container" style="padding: 3rem 1.5rem 10rem;">
    <div
      style="display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 30px; margin-bottom: 4rem;"
    >
      <div
        style="background: white; padding: 2.5rem; border-radius: 24px; border: 1px solid #eee; box-shadow: 0 10px 30px rgba(0,0,0,0.02);"
      >
        <h2
          style="color: #1b4332; font-weight: 900; margin-top: 0; font-size: 1.6rem;"
        >
          Regional Service Overview
        </h2>
        <p
          style="color: #4b5563; line-height: 1.8; font-size: 1.05rem; font-weight: 500;"
        >
          ProTreeTrim™ helps route homeowners and property managers toward relevant tree service options throughout the <strong
            >{displayCounty}</strong
          > landscape. {countyClimateNote}
          From high-density neighborhoods to rural residential outskirts, the planning questions usually include access, cleanup, nearby structures, and whether local documentation or permit review may be needed before non-emergency work begins.
        </p>
      </div>

      <div
        style="background: #f0fdf4; padding: 2.5rem; border-radius: 24px; border: 1px solid #dcfce7; display: flex; flex-direction: column; justify-content: center;"
      >
        <div
          style="display: flex; gap: 20px; align-items: center; margin-bottom: 15px;"
        >
          <span style="font-size: 2.5rem;">🏗️</span>
          <div>
            <h4
              style="margin: 0; color: #166534; font-size: 1.3rem; font-weight: 900;"
            >
              24/7 Coverage
            </h4>
            <p
              style="margin: 5px 0 0; color: #166534; font-weight: 600; opacity: 0.8;"
            >
Dispatch guidance across {cityCount} listed service zones.
            </p>
          </div>
        </div>
        <p style="color: #166534; font-size: 0.95rem; line-height: 1.6;">
          Participating local providers may use sectional dismantling, rigging, compact equipment, mats, or crane-assisted planning depending on tree size, access, soil conditions, and nearby structures in {displayCounty}.
        </p>
      </div>
    </div>


    {
      countySlug === "volusia" && (
        <AudioGuideBlock
          kicker="Audio Guide"
          title="Listen to the Volusia County tree service guide."
          description="A short audio summary for Volusia County homeowners comparing tree removal, stump grinding, emergency response, access, and permit planning questions before calling a tree service."
          audioSrc="/audio/volusia-county-tree-service-audio-guide.mp3"
          audioLabel="Volusia County tree service audio guide"
        />
      )
    }

    {
      countyMoneyGroups.length > 0 && (
        <section
          style="margin-bottom: 4rem; background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 30px; padding: 2rem; box-shadow: 0 10px 25px rgba(0,0,0,0.03);"
        >
          <div style="display: flex; align-items: flex-end; justify-content: space-between; gap: 18px; flex-wrap: wrap; margin-bottom: 1.5rem;">
            <div>
              <span style="display:inline-block; background:#fff7ed; color:#c2410c; border:1px solid #fed7aa; padding:5px 12px; border-radius:999px; font-size:0.72rem; font-weight:900; text-transform:uppercase;">
                Priority local service pages
              </span>
              <h2 style="margin:0.8rem 0 0.4rem; color:#1b4332; font-size:1.55rem; font-weight:900;">
                High-intent service hubs in {displayCounty}
              </h2>
              <p style="margin:0; color:#4b5563; line-height:1.7; max-width:760px;">
                These internal links help property owners move from county-level research to the most relevant city and service page.
              </p>
            </div>
            <a href="/blog/florida-tree-removal-permit-guide/" style="color:#ea580c; font-weight:900; text-decoration:none;">
              Florida permit guide →
            </a>
          </div>

          <div style="display:grid; grid-template-columns: repeat(auto-fit, minmax(250px, 1fr)); gap:16px;">
            {countyMoneyGroups.map((group) => (
              <div style="background:white; border:1px solid #e5e7eb; border-radius:20px; padding:1.2rem;">
                <h3 style="margin:0 0 0.35rem; color:#1b4332; font-size:1.08rem; font-weight:900;">
                  {group.city}
                </h3>
                <p style="margin:0 0 0.9rem; color:#64748b; font-size:0.86rem; line-height:1.5;">
                  {group.focus}
                </p>
                <div style="display:flex; flex-direction:column; gap:8px;">
                  {group.links.map((link) => (
                    <a href={link.href} class="service-link">
                      {link.eyebrow} →
                    </a>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </section>
      )
    }

    <section class="related-guides-section">
      <div class="related-guides-intro">
        <span style="display:inline-block; color:#ffb703; font-weight:900; font-size:0.72rem; text-transform:uppercase; margin-bottom:0.7rem;">
          County research paths
        </span>
        <h2 style="margin:0 0 0.8rem; font-size:1.45rem; color:white;">
          Useful guides for {countyName} property owners
        </h2>
        <p style="margin:0; color:#d1fae5; line-height:1.7;">
          These guides support the county hub with permit, emergency, stump, and risk-assessment context before users choose a city page.
        </p>
      </div>
      <div class="related-guide-list">
        {countyGuideLinks.map((guide) => (
          <a href={guide.href} class="related-guide-card">
            <span class="related-guide-kicker">Related guide</span>
            <strong>{guide.title}</strong>
            <span class="related-guide-cta">Read guide →</span>
          </a>
        ))}
      </div>
    </section>

    <h2
      style="text-align: center; color: #1b4332; font-weight: 900; font-size: 1.8rem; margin-bottom: 2.5rem;"
    >
      Select Your City in {countyName}
    </h2>

    <div
      style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 20px;"
    >
      {
        cities.map((city) => {
          return (
            <div
              style="background: white; padding: 1.8rem; border-radius: 20px; border: 1px solid #e5e7eb; transition: 0.3s; position: relative; overflow: hidden;"
              class="city-hub-card"
            >
              <div style="position: absolute; top: 0; left: 0; width: 4px; height: 100%; background: #16a34a;" />
              <h3 style="margin: 0 0 15px; color: #1b4332; font-size: 1.2rem; font-weight: 900;">
                {toTitleCase(city.City)}
              </h3>
              <div style="display: flex; flex-direction: column; gap: 12px;">
                <a href={cityServicePath("tree-removal", city.City, city.County)} class="service-link">
                  <span style="opacity: 0.8;">🌳</span> Tree Removal Service →
                </a>
                <a href={cityServicePath("stump-grinding", city.City, city.County)} class="service-link">
                  <span style="opacity: 0.8;">🏗️</span> Stump Grinding & Removal
                  →
                </a>
                <a
                  href={cityServicePath("emergency-service", city.City, city.County)}
                  class="service-link-emergency"
                >
                  <span style="filter: grayscale(0);">🌪️</span> Emergency
                  Response 24/7 →
                </a>
              </div>
              <div style="margin-top: 15px; padding-top: 15px; border-top: 1px solid #f1f5f9;">
                <small style="color: #94a3b8; font-weight: 700; text-transform: uppercase; font-size: 0.65rem;">
                  Primary Species
                </small>
                <p style="margin: 2px 0 0; font-size: 0.8rem; color: #475569; font-weight: 600;">
                  {city.MainTreeType}
                </p>
              </div>
            </div>
          );
        })
      }
    </div>

    <section
      style="margin-top: 6rem; padding: 3rem; background: #081c15; border-radius: 32px; color: white; position: relative; overflow: hidden;"
    >
      <div
        style="position: absolute; top: -20px; right: -20px; font-size: 10rem; opacity: 0.05; font-weight: 900;"
      >
        FL
      </div>
      <span style="display:inline-block; color:#ffb703; font-weight:900; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.75rem;">
        Permit & risk documentation notes
      </span>
      <h3
        style="color: #fff; font-size: 1.75rem; font-weight: 900; margin: 0 0 1rem;"
      >
        Tree removal permit notes for {displayCounty}
      </h3>
      <div style="display:grid; grid-template-columns: minmax(0, 1.6fr) minmax(260px, 0.8fr); gap: 26px; align-items:start;">
        <div>
          <p
            style="font-size: 1.05rem; line-height: 1.75; color: #d1fae5; margin-top:0; max-width: 940px;"
          >
            {countyPermit.summary}
          </p>
          <p
            style="font-size: 1rem; line-height: 1.75; color: #bbf7d0; max-width: 940px;"
          >
            {countyPermit.localContext}
          </p>
          <p
            style="font-size: 0.96rem; line-height: 1.7; color: #fed7aa; max-width: 940px; margin-bottom:0;"
          >
            {countyPermit.riskNote}
          </p>
        </div>
        <aside style="background:rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.14); border-radius:22px; padding:1.35rem;">
          <strong style="display:block; color:#ffb703; font-size:0.78rem; text-transform:uppercase; letter-spacing:0.08em; margin-bottom:0.8rem;">
            Verify before non-emergency work
          </strong>
          <ul style="margin:0; padding-left:1.1rem; color:#ecfdf5; line-height:1.7; font-size:0.92rem;">
            <li>City or county requirements</li>
            <li>HOA or community rules</li>
            <li>Protected/specimen tree status</li>
            <li>Mangrove, wetland, easement, or utility constraints</li>
          </ul>
          <div style="margin-top:1.15rem; padding-top:1rem; border-top:1px solid rgba(255,255,255,0.14); color:#a7f3d0; font-size:0.82rem; line-height:1.6;">
            Source note: <a href={countyPermit.officialUrl} style="color:#ffb703; font-weight:800;">{countyPermit.sourceLabel}</a><br />
            Last reviewed: {countyPermit.lastReviewed}
          </div>
        </aside>
      </div>
      <div style="margin-top: 2rem; display:flex; gap:12px; flex-wrap:wrap;">
        <a
          href="/blog/florida-tree-removal-permit-guide/"
          style="background: #ea580c; color: white; padding: 12px 25px; border-radius: 10px; text-decoration: none; font-weight: 800; font-size: 0.9rem;"
          >READ FLORIDA PERMIT GUIDE</a
        >
        <a
          href="/contact"
          style="background: rgba(255,255,255,0.08); border:1px solid rgba(255,255,255,0.18); color: white; padding: 12px 25px; border-radius: 10px; text-decoration: none; font-weight: 800; font-size: 0.9rem;"
          >CONTACT DISPATCH</a
        >
      </div>
    </section>
  </main>
</MainLayout>

<style>
  .city-hub-card:hover {
    border-color: #ea580c !important;
    box-shadow: var(--shadow-card-hover);
  }
  .related-guides-section {
    display: grid;
    gap: 1rem;
    grid-template-columns: minmax(260px, 0.85fr) minmax(0, 1.15fr);
    margin-bottom: 4rem;
  }
  .related-guides-intro {
    align-content: center;
    background: #081c15;
    border-radius: var(--radius-panel);
    color: white;
    display: grid;
    padding: 1.65rem;
  }
  .related-guide-list {
    align-self: center;
    display: grid;
    gap: 0.8rem;
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }
  .related-guide-card {
    align-content: start;
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: 18px;
    box-shadow: var(--shadow-card);
    color: inherit;
    display: grid;
    gap: 0.45rem;
    min-height: 0;
    min-width: 0;
    padding: 0.95rem 1rem;
    text-decoration: none;
  }
  .related-guide-card strong {
    color: #1b4332;
    display: block;
    font-size: 0.98rem;
    line-height: 1.35;
  }
  .related-guide-kicker {
    color: #16a34a;
    display: block;
    font-size: 0.68rem;
    font-weight: 900;
    letter-spacing: 0.04em;
    line-height: 1.2;
    text-transform: uppercase;
  }
  .related-guide-cta {
    color: #c2410c;
    display: inline-flex;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1.2;
    margin-top: 0.1rem;
  }
  .related-guide-card:hover {
    border-color: #ea580c !important;
    box-shadow: var(--shadow-card-hover) !important;
  }
  .service-link {
    text-decoration: none;
    color: #475569;
    font-size: 0.9rem;
    font-weight: 700;
    transition: 0.2s;
  }
  .service-link:hover {
    color: #16a34a;
    padding-left: 5px;
  }
  .service-link-emergency {
    text-decoration: none;
    color: #ea580c;
    font-size: 0.9rem;
    font-weight: 900;
    transition: 0.2s;
  }
  .service-link-emergency:hover {
    color: #c2410c;
    padding-left: 5px;
  }
  .city-hub-card,
  main.container a[style*="display:block; background:white"],
  main.container div[style*="background:white; border:1px solid #e5e7eb"] {
    box-shadow: var(--shadow-card) !important;
  }
  .city-hub-card,
  main.container div[style*="background:white; border:1px solid #e5e7eb"] {
    border-radius: var(--radius-card) !important;
  }
  main.container h2,
  main.container h3 {
    line-height: var(--heading-line-height) !important;
    text-wrap: balance;
  }
  main.container p,
  main.container li {
    line-height: var(--reading-line-height) !important;
  }
  @media (max-width: 760px) {
    .related-guides-section,
    .related-guide-list {
      grid-template-columns: 1fr;
    }

    .related-guides-intro {
      padding: 1.35rem;
    }

    .related-guide-card {
      padding: 0.95rem 1rem;
    }

    header h1,
    main.container h2,
    main.container h3 {
      line-height: var(--mobile-heading-line-height) !important;
    }

    section[style*="grid-template-columns: minmax(0, 1.6fr)"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
