---
// src/pages/contact.astro (GÜNCELLENDİ)
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config.js";
---

<MainLayout
  title="Contact Florida Tree Service Dispatch"
  description="Request tree service dispatch help in Florida, ask a tree concern question, or discuss storm damage, removal, stump grinding, permits, and callback timing."
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "ContactPage",
        name: "Contact Florida Tree Service Dispatch",
        description:
          "Request Florida tree service dispatch help, ask questions, or discuss tree concerns with ProTreeTrim.",
        url: `${SITE_CONFIG.siteUrl}/contact/`,
        mainEntity: {
          "@type": "Organization",
          name: SITE_CONFIG.brandName,
          telephone: SITE_CONFIG.phoneHref.replace("tel:", ""),
          email: SITE_CONFIG.email,
          areaServed: {
            "@type": "State",
            name: "Florida",
          },
        },
      })}
    />
  </Fragment>

  <header class="contact-hero">
    <div class="container">
      <p class="contact-eyebrow">Florida dispatch and estimate coordination</p>
      <h1>Discuss Your Tree Concern With Our Dispatch Team</h1>
      <p>
        Request help, ask a question, or share details about a tree concern. We
        review the information and help route eligible requests toward an
        appropriate local provider when applicable.
      </p>
      <div class="hero-actions" aria-label="Contact options">
        <a href={SITE_CONFIG.phoneHref}>Speak With Our Dispatch Team</a>
        <a href="#request-form">Request Local Assistance</a>
      </div>
    </div>
  </header>

  <main class="container contact-main">
    <section class="contact-methods" aria-label="Contact options">
        <h2 class="sr-only">Contact options</h2>
        <div style="background: #fff7ed; border: 2px solid #ea580c; padding: 2.5rem; border-radius: 24px; text-align: center;">
          <div style="font-size: 2.5rem; margin-bottom: 15px;">📞</div>
          <h3 style="color: #9a3412; margin: 0; font-size: 1.5rem; font-weight: 800;">24/7 Dispatch</h3>
          <p style="color: #7c2d12; font-size: 0.95rem; margin-bottom: 1.5rem;">For urgent tree concerns, storm damage questions, and estimate coordination.</p>
          <a href={SITE_CONFIG.phoneHref} aria-label={`Speak with ProTreeTrim dispatch at ${SITE_CONFIG.phone}`} style="background: #ea580c; color: white !important; padding: 12px 24px; text-decoration: none; border-radius: 12px; font-weight: 900; font-size: 1.2rem; display: block;">{SITE_CONFIG.phone}</a>
        </div>
        <div style="background: white; border: 1px solid #e2e8f0; padding: 2.5rem; border-radius: 24px; text-align: center; box-shadow: 0 10px 25px rgba(0,0,0,0.02);">
          <div style="font-size: 2.5rem; margin-bottom: 15px;">📧</div>
          <h3 style="color: #1b4332; margin: 0; font-size: 1.5rem; font-weight: 800;">Email Support</h3>
          <p style="color: #64748b; font-size: 0.95rem; margin-bottom: 1.5rem;">For non-urgent questions, business inquiries, and partnership conversations.</p>
          <a href={`mailto:${SITE_CONFIG.email}`} style="color: #ea580c; font-weight: 800; text-decoration: none; font-size: 1.1rem;">{SITE_CONFIG.email}</a>
        </div>
    </section>

    <section class="next-steps" aria-labelledby="next-steps-title">
      <div class="section-intro">
        <p>What happens next</p>
        <h2 id="next-steps-title">A simple dispatch review process</h2>
      </div>
      <ol>
        <li>
          <span>Step 1</span>
          <strong>Submit a request or call.</strong>
          <p>Share the city, service need, and what is happening on the property.</p>
        </li>
        <li>
          <span>Step 2</span>
          <strong>Your information is reviewed.</strong>
          <p>Dispatch checks the request details, timing, and service category.</p>
        </li>
        <li>
          <span>Step 3</span>
          <strong>A local provider may be matched.</strong>
          <p>When applicable, the request is routed toward an appropriate local provider.</p>
        </li>
        <li>
          <span>Step 4</span>
          <strong>The provider contacts you.</strong>
          <p>You can discuss availability, scope, photos, access, and any next steps.</p>
        </li>
      </ol>
    </section>

    <section class="trust-reasons" aria-labelledby="trust-reasons-title">
      <div class="section-intro">
        <p>Why homeowners contact us</p>
        <h2 id="trust-reasons-title">Helpful routing for common tree concerns</h2>
      </div>
      <div class="reason-grid">
        <article>
          <strong>Storm damage questions</strong>
          <span>Leaning trees, broken limbs, roof contact, blocked access, and cleanup timing.</span>
        </article>
        <article>
          <strong>Tree removal guidance</strong>
          <span>Dead, hazardous, crowded, or poorly located trees that need review.</span>
        </article>
        <article>
          <strong>Palm and pruning issues</strong>
          <span>Overgrown palms, hanging fronds, canopy clearance, and seasonal trimming questions.</span>
        </article>
        <article>
          <strong>Permit and documentation concerns</strong>
          <span>HOA notes, insurance photos, city questions, and property-specific constraints.</span>
        </article>
      </div>
    </section>

    <section class="partnership-bridge" aria-label="Partnership opportunities">
      <div>
        <strong>Looking beyond a service request?</strong>
        <span>Explore selected sponsorship, territory, content, and local growth opportunity conversations through the ProTreeTrim™ Partnerships page.</span>
      </div>
      <a href="/partnerships/">Explore Partnerships →</a>
    </section>

    <div class="request-layout">
      <section id="request-form" class="form-panel" aria-labelledby="request-form-title">
        <h2 id="request-form-title">Request Local Assistance</h2>
        <p class="privacy-note">
          Your information is used only to handle this request. There is no
          obligation, and ProTreeTrim does not use this form for spam outreach.
        </p>

        <form class="contact-form" action="/api/contact" method="POST" aria-label="Request local tree service assistance" style="display: flex; flex-direction: column; gap: 15px;">
          <!-- TUZAK -->
          <div style="display:none;" aria-hidden="true"><input type="text" name="fax_number" tabindex="-1" autocomplete="off" /></div>

          <div>
            <label for="contact-name" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">Your Name</label>
            <input id="contact-name" type="text" name="name" autocomplete="name" placeholder="John Doe" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; outline: none;" required />
          </div>

          <!-- YENİ: E-mail ve Phone yan yana -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div>
              <label for="contact-email" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">Email Address</label>
              <input id="contact-email" type="email" name="email" autocomplete="email" placeholder="john@example.com" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; outline: none;" required />
            </div>
            <div>
              <label for="contact-phone" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">Phone</label>
              <input id="contact-phone" type="tel" name="phone" autocomplete="tel" placeholder="(555) 000-0000" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; outline: none;" required />
            </div>
          </div>

          <!-- City ve Service yan yana -->
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 15px;">
            <div>
              <label for="contact-city" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">City</label>
              <input id="contact-city" type="text" name="city" autocomplete="address-level2" placeholder="e.g. Miami" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; outline: none;" required />
            </div>
            <div>
              <label for="contact-service" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">Service Needed</label>
              <select id="contact-service" name="service" style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; background: white;">
                <option>Tree Removal</option>
                <option>Stump Grinding</option>
                <option>Emergency Service</option>
                <option>General Pruning</option>
              </select>
            </div>
          </div>

          <div>
            <label for="contact-message" style="display: block; font-size: 0.85rem; font-weight: 700; color: #4b5563; margin-bottom: 5px;">Message</label>
            <textarea id="contact-message" name="message" rows="4" placeholder="Tell us what happened, where the tree is located, and when you prefer a callback." style="width: 100%; padding: 12px; border-radius: 8px; border: 1px solid #ddd; resize: vertical;"></textarea>
          </div>
          <button type="submit" aria-label="Request local tree service assistance" style="background: var(--primary); color: white; padding: 15px; border: none; border-radius: 8px; font-weight: 800; cursor: pointer;">Request Local Assistance</button>
        </form>
      </section>

      <aside class="contact-prep" aria-labelledby="prep-title">
        <h2 id="prep-title">Before You Contact Us</h2>
        <p>These details help dispatch understand the situation faster.</p>
        <ul>
          <li>Property address or nearest cross street</li>
          <li>Tree location on the property</li>
          <li>Whether storm damage is involved</li>
          <li>Photos, if available and safe to take</li>
          <li>HOA or permit concerns, if applicable</li>
          <li>Preferred callback time</li>
        </ul>
        <h2 style="color: #1b4332; font-size: 1.8rem; font-weight: 800; margin-top: 0;">Statewide Coverage</h2>
        <p style="color: #4b5563; line-height: 1.8; margin-bottom: 2rem;">ProTreeTrim™ coordinates dispatch requests across all <strong>67 Florida counties</strong> through a local provider network.</p>
        <div style="overflow: hidden; border-radius: 24px; border: 1px solid #e2e8f0; line-height: 0; box-shadow: 0 10px 30px rgba(0,0,0,0.05);"><iframe title="Map showing Florida statewide coverage" width="100%" height="450" style="border:0" loading="lazy" allowfullscreen src="https://maps.google.com/maps?q=Florida&t=&z=6&ie=UTF8&iwloc=&output=embed"></iframe></div>
      </aside>
    </div>
  </main>
</MainLayout>

<style>
  .contact-hero {
    background: linear-gradient(135deg, #1b4332 0%, #081c15 100%);
    color: white;
    padding: 5rem 1.5rem;
    text-align: center;
  }

  .contact-hero h1 {
    font-size: clamp(2.15rem, 7vw, 3.65rem);
    margin: 0 auto;
    font-weight: 900;
    max-width: 880px;
    line-height: var(--heading-line-height);
    text-wrap: balance;
  }

  .contact-hero p:not(.contact-eyebrow) {
    font-size: 1.13rem;
    color: #c7f9d4;
    margin: 1rem auto 0;
    max-width: 760px;
    line-height: 1.7;
  }

  .contact-eyebrow {
    color: #ffb703;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.9rem;
    text-transform: uppercase;
  }

  .hero-actions {
    display: flex;
    justify-content: center;
    gap: 0.85rem;
    flex-wrap: wrap;
    margin-top: 2rem;
  }

  .hero-actions a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 3.15rem;
    padding: 0 1.2rem;
    border-radius: 12px;
    text-decoration: none;
    font-weight: 900;
  }

  .hero-actions a:first-child {
    background: #ea580c;
    color: white;
  }

  .hero-actions a:last-child {
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: white;
  }

  .contact-main {
    max-width: 1100px;
    padding: 4rem 1.5rem 12rem;
  }

  .contact-methods {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 30px;
    margin-bottom: 4rem;
  }

  .sr-only {
    border: 0;
    clip: rect(0, 0, 0, 0);
    height: 1px;
    margin: -1px;
    overflow: hidden;
    padding: 0;
    position: absolute;
    white-space: nowrap;
    width: 1px;
  }

  .section-intro {
    text-align: center;
    max-width: 760px;
    margin: 0 auto 1.8rem;
  }

  .section-intro p {
    color: #c2410c;
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.55rem;
    text-transform: uppercase;
  }

  .section-intro h2 {
    color: #1b4332;
    font-size: clamp(1.65rem, 4vw, 2.25rem);
    line-height: var(--heading-line-height);
    margin: 0;
    text-wrap: balance;
  }

  .next-steps {
    margin-bottom: 4rem;
  }

  .next-steps ol {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: 1rem;
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: dispatch-step;
  }

  .next-steps li {
    position: relative;
    background: var(--surface-card);
    border: var(--border-soft);
    border-radius: var(--radius-card);
    padding: var(--card-padding);
    box-shadow: var(--shadow-card);
  }

  .next-steps li:not(:last-child)::after {
    content: "→";
    position: absolute;
    right: -0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: #94a3b8;
    font-weight: 900;
  }

  .next-steps span {
    display: inline-block;
    color: #c2410c;
    font-size: 0.72rem;
    font-weight: 900;
    margin-bottom: 0.65rem;
    text-transform: uppercase;
  }

  .next-steps strong {
    display: block;
    color: #123729;
    font-size: 1rem;
    line-height: 1.35;
  }

  .next-steps p {
    color: #526253;
    font-size: 0.92rem;
    line-height: 1.55;
    margin: 0.55rem 0 0;
  }

  .trust-reasons {
    margin-bottom: 4rem;
  }

  .reason-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: 1rem;
  }

  .reason-grid article {
    background: var(--surface-muted);
    border: var(--border-soft);
    border-radius: var(--radius-card);
    box-shadow: var(--shadow-card);
    padding: var(--card-padding);
  }

  .reason-grid strong {
    display: block;
    color: #1b4332;
    margin-bottom: 0.45rem;
  }

  .reason-grid span {
    color: #526253;
    line-height: 1.55;
    font-size: 0.95rem;
  }

  .partnership-bridge {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.25rem;
    margin: -2rem 0 3rem;
    padding: 1.35rem 1.5rem;
    border-radius: 24px;
    border: 1px solid #c9efd4;
    background: #f2fff5;
    box-shadow: var(--shadow-card);
  }

  .partnership-bridge div {
    display: grid;
    gap: 0.35rem;
  }

  .partnership-bridge strong {
    color: #0f3f2a;
    font-size: 1.05rem;
    font-weight: 900;
  }

  .partnership-bridge span {
    color: #526253;
    line-height: 1.6;
  }

  .partnership-bridge a {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    min-height: 3rem;
    padding: 0 1.15rem;
    border-radius: 999px;
    background: #f25a06;
    color: white;
    text-decoration: none;
    font-weight: 900;
    box-shadow: var(--shadow-cta);
  }

  .request-layout {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 3.5rem;
    align-items: start;
  }

  .form-panel {
    background: white;
    padding: 2.35rem;
    border-radius: var(--radius-panel);
    border: var(--border-soft);
    box-shadow: var(--shadow-card);
  }

  .form-panel h2,
  .contact-prep h2 {
    color: #1b4332;
    font-size: 1.8rem;
    font-weight: 800;
    line-height: var(--heading-line-height);
    margin-top: 0;
    margin-bottom: 1rem;
  }

  .privacy-note {
    background: #f0fdf4;
    border: 1px solid #bbf7d0;
    border-radius: 14px;
    color: #166534;
    line-height: 1.6;
    margin: 0 0 1.35rem;
    padding: 1rem;
  }

  .contact-form {
    gap: 1rem !important;
  }

  .contact-form input:focus,
  .contact-form select:focus,
  .contact-form textarea:focus,
  .contact-form button:focus,
  .hero-actions a:focus,
  .partnership-bridge a:focus {
    outline: 3px solid #ffb703 !important;
    outline-offset: 3px;
    border-color: #1b4332 !important;
  }

  .contact-form button:hover,
  .hero-actions a:hover,
  .partnership-bridge a:hover {
    box-shadow: var(--shadow-card-hover);
  }

  .contact-prep {
    background: #ffffff;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    padding: 2rem;
    box-shadow: var(--shadow-card);
  }

  .contact-prep > p {
    color: #4b5563;
    line-height: 1.7;
    margin-top: 0;
  }

  .contact-prep ul {
    display: grid;
    gap: 0.7rem;
    margin: 0 0 2rem;
    padding: 0;
    list-style: none;
  }

  .contact-prep li {
    color: #334155;
    line-height: 1.55;
    padding-left: 1.7rem;
    position: relative;
  }

  .contact-prep li::before {
    content: "✓";
    color: #16a34a;
    font-weight: 900;
    left: 0;
    position: absolute;
  }

  @media (max-width: 760px) {
    .partnership-bridge {
      flex-direction: column;
      align-items: flex-start;
      margin-top: 0;
    }

    .next-steps ol {
      grid-template-columns: 1fr;
    }

    .next-steps li:not(:last-child)::after {
      content: "↓";
      left: 50%;
      right: auto;
      top: auto;
      bottom: -1.1rem;
      transform: translateX(-50%);
    }

    .request-layout {
      grid-template-columns: 1fr;
      gap: 2rem;
    }

    .contact-main {
      padding: 3.5rem 1.2rem 10rem;
    }

    .form-panel,
    .contact-prep {
      padding: 1.4rem;
    }

    .contact-form > div[style*="grid-template-columns"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
