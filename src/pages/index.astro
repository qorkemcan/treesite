---
import fs from "node:fs";
import path from "node:path";
import { parse } from "csv-parse/sync";
import MainLayout from "../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../config.js";
import { cityServicePath, countySlug as makeCountySlug } from "../lib/slugs.js";
import PriceCalculator from "../components/PriceCalculator.astro";

const filePath = path.resolve("./src/data/cities.csv");
const fileContent = fs.readFileSync(filePath, "utf-8");
const records = parse(fileContent, {
  columns: true,
  skip_empty_lines: true,
  bom: true,
});

const currentYear = new Date().getFullYear();
const currentMonth = new Date().toLocaleString("en-US", { month: "long" });

const seenCities = new Set();
const groupedCities = records.reduce((acc: any, city: any) => {
  const cityName = city.City.trim();
  const lowerCity = cityName.toLowerCase();

  if (!seenCities.has(lowerCity)) {
    seenCities.add(lowerCity);
    const county = city.County || "Florida Areas";
    if (!acc[county]) acc[county] = [];
    acc[county].push(city);
  }
  return acc;
}, {});

const counties = Object.keys(groupedCities).sort();

const toTitleCase = (str) => {
  if (!str) return "";
  return str
    .toLowerCase()
    .split(" ")
    .map((word) => word.charAt(0).toUpperCase() + word.slice(1))
    .join(" ");
};

const featuredCities = [
  { name: "Miami", slug: "miami", desc: "Miami-Dade" },
  { name: "Orlando", slug: "orlando", desc: "Central Florida" },
  { name: "Tampa", slug: "tampa", desc: "Tampa Bay" },
  { name: "Jacksonville", slug: "jacksonville", desc: "Northeast Florida" },
  { name: "Fort Lauderdale", slug: "fort-lauderdale", desc: "Broward" },
  { name: "Cape Coral", slug: "cape-coral", desc: "Southwest Florida" },
];

const quickDecisionCards = [
  {
    title: "Emergency Tree Help",
    text: "Storm damage, blocked access, split trunks, or trees near structures.",
    href: "/services/emergency-response/",
  },
  {
    title: "Tree Removal",
    text: "Understand removal options, risk factors, access issues, and cleanup steps.",
    href: "/services/tree-removal/",
  },
  {
    title: "Tree Health",
    text: "Review disease, decline, pests, leaning, hollow trunks, and root concerns.",
    href: "/blog/category/tree-health-and-disease/",
  },
  {
    title: "Storm Recovery",
    text: "Prepare, document damage, and think through safer post-storm decisions.",
    href: "/blog/category/storm-prep-and-recovery/",
  },
  {
    title: "Palm Trees",
    text: "Florida palm trimming, yellowing fronds, hurricane cuts, and removal risk.",
    href: "/blog/category/palm-tree-care/",
  },
  {
    title: "Permits & Rules",
    text: "Find practical guidance for permits, HOA issues, documentation, and local rules.",
    href: "/blog/category/permits-and-regulations/",
  },
];

const homeownerReasons = [
  {
    title: "Clear guidance",
    text: "Plain-language information helps you understand the decision before requesting work.",
  },
  {
    title: "Florida-focused information",
    text: "Storms, palms, oaks, permits, sandy soils, and county differences shape tree decisions here.",
  },
  {
    title: "Practical homeowner answers",
    text: "Resources focus on what to inspect, what to ask, and what to document.",
  },
  {
    title: "Easy navigation",
    text: "Start by city, county, service, situation, or homeowner question.",
  },
];

const popularResources = [
  {
    title: "Emergency Tree Removal in Florida",
    label: "Storm",
    href: "/blog/emergency-tree-removal-florida/",
    text: "What counts as urgent, what to document, and when to keep people away.",
  },
  {
    title: "Do Palms Need Trimming Before Hurricane Season?",
    label: "Palm",
    href: "/blog/do-palms-need-trimming-before-hurricane-season/",
    text: "How to think about palm trimming without encouraging harmful hurricane cuts.",
  },
  {
    title: "What Is a Critical Root Zone?",
    label: "Roots",
    href: "/blog/what-is-a-critical-root-zone-and-why-does-it-matter-before-tree-work/",
    text: "Why root space matters before construction, trimming, or removal decisions.",
  },
  {
    title: "Common Pests Attacking Florida Oak Trees",
    label: "Oak",
    href: "/blog/common-pests-attacking-florida-oak-trees/",
    text: "A homeowner-friendly look at warning signs around Florida oaks.",
  },
  {
    title: "Florida Tree Removal Permit Guide",
    label: "Permits",
    href: "/blog/florida-tree-removal-permit-guide/",
    text: "How local rules, documentation, and protected trees can affect next steps.",
  },
  {
    title: "How to Identify Structural Weaknesses Before Hurricane Season",
    label: "Storm prep",
    href: "/blog/how-to-identify-structural-weaknesses-before-hurricane-season/",
    text: "What homeowners can observe safely before conditions become urgent.",
  },
];

const situations = [
  {
    title: "After a storm",
    href: "/blog/category/storm-prep-and-recovery/",
    text: "Damage, leaning trees, hanging limbs, cleanup timing, and documentation.",
  },
  {
    title: "Buying a home",
    href: "/blog/florida-tree-questions-to-ask-before-buying-a-home-with-mature-trees/",
    text: "Questions to ask when mature trees could affect cost, safety, or insurance.",
  },
  {
    title: "Selling a home",
    href: "/blog/tree-maintenance-for-vacation-homes-and-seasonal-residents-in-florida/",
    text: "Reduce visible risk concerns before buyers, inspectors, or storms arrive.",
  },
  {
    title: "Palm concerns",
    href: "/blog/category/palm-tree-care/",
    text: "Yellowing fronds, pests, pruning timing, and removal warning signs.",
  },
  {
    title: "Oak concerns",
    href: "/blog/common-pests-attacking-florida-oak-trees/",
    text: "Large-canopy tree questions, decay, pests, limbs, and structure.",
  },
  {
    title: "Root problems",
    href: "/blog/category/stump-and-root/",
    text: "Pavers, sidewalks, pool decks, construction damage, and root-zone issues.",
  },
  {
    title: "Tree removal questions",
    href: "/blog/category/tree-removal-decision-guides/",
    text: "When removal makes sense, when it may not, and what affects the quote.",
  },
];
---

<MainLayout
  title="Florida Tree Care Guidance for Homeowners"
  description="Find practical Florida tree care guidance, service directories, storm recovery resources, permit information, and local dispatch options for homeowners."
>
  <main id="main-content">
    <header class="home-hero">
      <div class="container hero-inner">
        <div class="hero-copy">
          <p class="eyebrow">Updated {currentMonth} {currentYear}</p>
          <h1>Helping Florida Homeowners Make Better Tree Care Decisions</h1>
          <p>
            Search your city, compare common tree concerns, and find practical
            guidance before deciding whether to request local help.
          </p>
          <div class="hero-actions" aria-label="Homepage starting points">
            <a href="#quick-decisions">Browse common situations</a>
            <a href="/trust-safety/">How trust & safety works</a>
          </div>
        </div>

        <div class="search-panel" aria-labelledby="search-title">
          <h2 id="search-title">Find your local tree service area</h2>
          <p>
            Type a Florida city or county to open matching local dispatch
            directories.
          </p>
          <div class="search-box">
            <span aria-hidden="true">🔍</span>
            <input
              type="text"
              id="citySearch"
              aria-label="Search Florida cities and counties"
              placeholder="Search city or county"
            />
          </div>
        </div>
      </div>
    </header>

    <div class="container page-flow">
      <section id="quick-decisions" class="section-block" aria-labelledby="quick-title">
        <div class="section-heading">
          <p>Where to begin</p>
          <h2 id="quick-title">Quick decisions homeowners often face</h2>
        </div>
        <div class="decision-grid">
          {
            quickDecisionCards.map((card) => (
              <a href={card.href} class="decision-card">
                <strong>{card.title}</strong>
                <span>{card.text}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-block" aria-labelledby="why-title">
        <div class="section-heading">
          <p>Why homeowners use ProTreeTrim</p>
          <h2 id="why-title">Guidance before decisions</h2>
        </div>
        <div class="reason-grid">
          {
            homeownerReasons.map((item) => (
              <article>
                <h3>{item.title}</h3>
                <p>{item.text}</p>
              </article>
            ))
          }
        </div>
      </section>

      <section class="section-block calculator-band" aria-labelledby="calculator-title">
        <div class="section-heading">
          <p>Plan with context</p>
          <h2 id="calculator-title">Estimate factors before you call</h2>
        </div>
        <PriceCalculator />
      </section>

      <section class="section-block" aria-labelledby="popular-title">
        <div class="section-heading">
          <p>Popular resources</p>
          <h2 id="popular-title">High-value guides for Florida homeowners</h2>
        </div>
        <div class="resource-grid">
          {
            popularResources.map((resource) => (
              <a href={resource.href} class="resource-card">
                <span>{resource.label}</span>
                <strong>{resource.title}</strong>
                <p>{resource.text}</p>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-block" aria-labelledby="situation-title">
        <div class="section-heading">
          <p>Browse by situation</p>
          <h2 id="situation-title">Start with what is happening on the property</h2>
        </div>
        <div class="situation-grid">
          {
            situations.map((item) => (
              <a href={item.href} class="situation-card">
                <strong>{item.title}</strong>
                <span>{item.text}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section class="section-block" aria-labelledby="region-title">
        <div class="section-heading">
          <p>Browse by Florida region</p>
          <h2 id="region-title">Common starting points across the state</h2>
        </div>
        <div class="region-grid">
          {
            featuredCities.map((city) => (
              <a href={`/tree-removal-${city.slug}/`} class="region-card">
                <strong>{city.name}</strong>
                <span>{city.desc}</span>
              </a>
            ))
          }
        </div>
      </section>

      <section id="directory" class="section-block directory-section" aria-labelledby="directory-title">
        <div class="section-heading">
          <p>County directory</p>
          <h2 id="directory-title">Browse local dispatch by county</h2>
        </div>

        <div id="countyGrid" class="directory-grid">
          {
            counties.map((county) => {
              const countySlug = makeCountySlug(county);
              return (
                <div class="county-card" data-county={county.toLowerCase()}>
                  <div class="county-card-top">
                    <button class="county-toggle" aria-expanded="false">
                      <span class="county-name">{toTitleCase(county)}</span>
                      <span class="chevron" aria-hidden="true">▼</span>
                    </button>
                    <a
                      href={`/county/${countySlug}`}
                      title={`View all cities in ${county}`}
                      class="county-hub-link"
                    >
                      County hub
                    </a>
                  </div>

                  <div class="city-list-content">
                    <div class="city-list-inner">
                      {groupedCities[county].map((city: any) => {
                        return (
                          <div
                            class="city-item"
                            data-city={city.City.toLowerCase()}
                          >
                            <a
                              href={cityServicePath("tree-removal", city.City, city.County)}
                              class="main-service-link"
                            >
                              {toTitleCase(city.City)} Tree Service
                            </a>
                            <div class="sub-services">
                              <a href={cityServicePath("stump-grinding", city.City, city.County)}>Stump Grinding</a>
                              <a href={cityServicePath("emergency-service", city.City, city.County)}>Emergency</a>
                            </div>
                          </div>
                        );
                      })}
                      <a href={`/county/${countySlug}`} class="full-directory-link">
                        View full {toTitleCase(county)} directory
                      </a>
                    </div>
                  </div>
                </div>
              );
            })
          }
        </div>
      </section>

      <section class="section-block trust-band" aria-labelledby="trust-title">
        <div>
          <p class="eyebrow-dark">Trust starts with context</p>
          <h2 id="trust-title">Guidance comes before decisions</h2>
          <p>
            ProTreeTrim helps homeowners understand tree concerns, safety
            questions, and local considerations before requesting work. Review
            the trust process, learn about the network, or contact dispatch with
            a question.
          </p>
        </div>
        <div class="trust-links" aria-label="Trust resources">
          <a href="/trust-safety/">Trust & Safety</a>
          <a href="/about/">About</a>
          <a href="/contact/">Contact</a>
        </div>
      </section>

      <section class="soft-cta" aria-labelledby="soft-cta-title">
        <h2 id="soft-cta-title">Need help understanding your situation?</h2>
        <p>
          Ask a question, describe what is happening on the property, or discuss
          whether local assistance may make sense.
        </p>
        <a href={SITE_CONFIG.phoneHref} aria-label={`Discuss your tree question with ProTreeTrim at ${SITE_CONFIG.phone}`}>
          Discuss Your Tree Question
        </a>
      </section>
    </div>
  </main>
</MainLayout>

<style>
  .home-hero {
    background: linear-gradient(135deg, #1b4332 0%, #081c15 100%);
    border-bottom: 6px solid #ea580c;
    color: white;
    padding: 5.5rem 1.5rem;
  }

  .hero-inner {
    align-items: center;
    display: grid;
    gap: 3rem;
    grid-template-columns: minmax(0, 1.05fr) minmax(320px, 0.95fr);
  }

  .hero-copy h1 {
    font-size: clamp(2.35rem, 6vw, 4.45rem);
    font-weight: 900;
    letter-spacing: 0;
    line-height: 1.02;
    margin: 0;
    max-width: 820px;
  }

  .hero-copy > p:not(.eyebrow) {
    color: #c7f9d4;
    font-size: 1.16rem;
    line-height: 1.75;
    margin: 1.35rem 0 0;
    max-width: 720px;
  }

  .eyebrow,
  .eyebrow-dark,
  .section-heading p {
    font-size: 0.78rem;
    font-weight: 900;
    letter-spacing: 0.08em;
    margin: 0 0 0.65rem;
    text-transform: uppercase;
  }

  .eyebrow {
    color: #ffb703;
  }

  .eyebrow-dark,
  .section-heading p {
    color: #c2410c;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 1.8rem;
  }

  .hero-actions a,
  .trust-links a,
  .soft-cta a {
    align-items: center;
    border-radius: 12px;
    display: inline-flex;
    font-weight: 900;
    justify-content: center;
    min-height: 3rem;
    padding: 0.85rem 1.05rem;
    text-decoration: none;
  }

  .hero-actions a:first-child,
  .soft-cta a {
    background: #ea580c;
    color: white;
  }

  .hero-actions a:last-child {
    border: 1px solid rgba(255, 255, 255, 0.35);
    color: white;
  }

  .search-panel {
    background: white;
    border: 1px solid rgba(255, 255, 255, 0.3);
    border-radius: 24px;
    box-shadow: 0 18px 45px rgba(0, 0, 0, 0.25);
    padding: 2rem;
  }

  .search-panel h2 {
    color: #1b4332;
    font-size: 1.55rem;
    margin: 0 0 0.55rem;
  }

  .search-panel p {
    color: #526253;
    line-height: 1.6;
    margin: 0 0 1.2rem;
  }

  .search-box {
    align-items: center;
    border: 2px solid #fed7aa;
    border-radius: 16px;
    display: flex;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
  }

  .search-box input {
    border: 0;
    color: #1b4332;
    font-size: 1rem;
    font-weight: 700;
    outline: none;
    width: 100%;
  }

  .page-flow {
    padding: 5rem 1.2rem 12rem;
  }

  .section-block {
    margin-bottom: 5.5rem;
  }

  .section-heading {
    margin: 0 auto 2rem;
    max-width: 760px;
    text-align: center;
  }

  .section-heading h2,
  .trust-band h2,
  .soft-cta h2 {
    color: #064e3b;
    font-size: clamp(1.75rem, 4vw, 2.35rem);
    font-weight: 900;
    line-height: 1.15;
    margin: 0;
  }

  .decision-grid,
  .reason-grid,
  .resource-grid,
  .situation-grid,
  .region-grid {
    display: grid;
    gap: 1rem;
  }

  .decision-grid {
    grid-template-columns: repeat(3, minmax(0, 1fr));
  }

  .reason-grid,
  .resource-grid {
    grid-template-columns: repeat(4, minmax(0, 1fr));
  }

  .situation-grid {
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  }

  .region-grid {
    grid-template-columns: repeat(6, minmax(0, 1fr));
  }

  .decision-card,
  .resource-card,
  .situation-card,
  .region-card {
    background: white;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-card);
    color: inherit;
    display: block;
    min-height: 100%;
    padding: 1.35rem;
    text-decoration: none;
  }

  .reason-grid article {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-card);
    padding: 1.35rem;
  }

  .decision-card strong,
  .resource-card strong,
  .situation-card strong,
  .region-card strong,
  .reason-grid h3 {
    color: #1b4332;
    display: block;
    font-size: 1.05rem;
    line-height: 1.35;
    margin: 0 0 0.5rem;
  }

  .decision-card span,
  .situation-card span,
  .region-card span,
  .reason-grid p,
  .resource-card p,
  .trust-band p,
  .soft-cta p {
    color: #526253;
    line-height: 1.65;
    margin: 0;
  }

  .resource-card span {
    background: #fff7ed;
    border: 1px solid #fed7aa;
    border-radius: 999px;
    color: #c2410c;
    display: inline-block;
    font-size: 0.72rem;
    font-weight: 900;
    margin-bottom: 0.9rem;
    padding: 0.3rem 0.7rem;
    text-transform: uppercase;
  }

  .calculator-band {
    background: #f8fafc;
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    padding: 2rem;
  }

  .directory-section {
    background: #ffffff;
    border-top: 2px solid #f1f5f9;
    padding-top: 4rem;
  }

  .directory-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(3, 1fr);
  }

  .county-card {
    background: white;
    border: 1px solid #e5e7eb;
    border-radius: var(--radius-card);
    height: fit-content;
    overflow: hidden;
  }

  .county-card-top {
    align-items: stretch;
    display: flex;
  }

  .county-toggle {
    align-items: center;
    background: none;
    border: none;
    cursor: pointer;
    display: flex;
    flex: 1;
    justify-content: space-between;
    min-height: 3.5rem;
    padding: 1rem;
    text-align: left;
  }

  .county-name {
    color: #1b4332;
    font-size: 0.95rem;
    font-weight: 900;
  }

  .county-hub-link {
    align-items: center;
    border-left: 1px solid #f1f5f9;
    color: #c2410c;
    display: inline-flex;
    font-size: 0.78rem;
    font-weight: 900;
    padding: 0 1rem;
    text-decoration: none;
    white-space: nowrap;
  }

  .chevron {
    color: #94a3b8;
    font-size: 0.7rem;
    transition: transform 0.3s;
  }

  .city-list-content {
    background: #fff;
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0, 1, 0, 1);
  }

  .county-card.is-open .city-list-content {
    max-height: 5000px;
    transition: max-height 0.4s ease-in-out;
  }

  .county-card.is-open .chevron {
    color: #c2410c;
    transform: rotate(180deg);
  }

  .county-card.is-open {
    border-color: #ea580c;
  }

  .city-list-inner {
    border-top: 1px solid #f1f5f9;
    display: grid;
    gap: 0.9rem;
    padding: 1.2rem;
  }

  .city-item {
    border-bottom: 1px solid #f8fafc;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding-bottom: 0.75rem;
  }

  .main-service-link {
    color: #1b4332;
    font-size: 0.9rem;
    font-weight: 900;
    text-decoration: none;
  }

  .sub-services {
    display: flex;
    flex-wrap: wrap;
    gap: 0.65rem;
  }

  .sub-services a {
    color: #64748b;
    font-size: 0.72rem;
    font-weight: 800;
    text-decoration: none;
  }

  .full-directory-link {
    border-top: 1px dashed #e2e8f0;
    color: #15803d;
    font-size: 0.85rem;
    font-weight: 900;
    padding-top: 0.8rem;
    text-align: center;
    text-decoration: none;
  }

  .trust-band {
    align-items: center;
    background: #ecfdf5;
    border: 1px solid #bbf7d0;
    border-radius: var(--radius-panel);
    display: grid;
    gap: 2rem;
    grid-template-columns: 1fr auto;
    padding: 2rem;
  }

  .trust-band p:not(.eyebrow-dark) {
    margin-top: 1rem;
    max-width: 740px;
  }

  .trust-links {
    display: grid;
    gap: 0.65rem;
    min-width: 180px;
  }

  .trust-links a {
    background: white;
    border: 1px solid #bbf7d0;
    color: #166534;
  }

  .soft-cta {
    border: 1px solid #e2e8f0;
    border-radius: var(--radius-panel);
    padding: 2.5rem;
    text-align: center;
  }

  .soft-cta p {
    margin: 1rem auto 1.6rem;
    max-width: 640px;
  }

  a:focus,
  button:focus,
  input:focus {
    outline: 3px solid #ffb703;
    outline-offset: 3px;
  }

  .decision-card:hover,
  .resource-card:hover,
  .situation-card:hover,
  .region-card:hover,
  .county-card:hover {
    border-color: #ea580c;
    box-shadow: var(--shadow-card-hover);
  }

  @media (max-width: 1050px) {
    .hero-inner,
    .trust-band {
      grid-template-columns: 1fr;
    }

    .decision-grid,
    .reason-grid,
    .resource-grid,
    .region-grid,
    .directory-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 700px) {
    .home-hero {
      padding: 4.5rem 1.2rem;
    }

    .page-flow {
      padding: 4rem 1.2rem 10rem;
    }

    .section-block {
      margin-bottom: 4rem;
    }

    .decision-grid,
    .reason-grid,
    .resource-grid,
    .region-grid,
    .directory-grid {
      grid-template-columns: 1fr;
    }

    .county-card-top {
      flex-direction: column;
    }

    .county-hub-link {
      border-left: 0;
      border-top: 1px solid #f1f5f9;
      min-height: 2.75rem;
    }

    .calculator-band,
    .trust-band,
    .soft-cta {
      padding: 1.35rem;
    }
  }
</style>

<script is:inline>
  const searchInput = document.getElementById("citySearch");
  const countyCards = document.querySelectorAll(".county-card");

  countyCards.forEach((card) => {
    const btn = card.querySelector(".county-toggle");
    btn.addEventListener("click", () => {
      const isOpen = card.classList.contains("is-open");
      card.classList.toggle("is-open", !isOpen);
      btn.setAttribute("aria-expanded", String(!isOpen));
    });
  });

  searchInput.addEventListener("input", (e) => {
    const term = e.target.value.toLowerCase().trim();
    countyCards.forEach((card) => {
      const countyName = card.getAttribute("data-county");
      const cityItems = card.querySelectorAll(".city-item");
      let hasVisibleCity = false;

      if (term.length === 0) {
        card.style.display = "block";
        card.classList.remove("is-open");
        card.querySelector(".county-toggle")?.setAttribute("aria-expanded", "false");
        cityItems.forEach((i) => (i.style.display = "flex"));
        return;
      }

      cityItems.forEach((item) => {
        const cityName = item.getAttribute("data-city");
        if (cityName.includes(term) || countyName.includes(term)) {
          item.style.display = "flex";
          hasVisibleCity = true;
        } else {
          item.style.display = "none";
        }
      });

      if (hasVisibleCity || countyName.includes(term)) {
        card.style.display = "block";
        card.classList.add("is-open");
        card.querySelector(".county-toggle")?.setAttribute("aria-expanded", "true");
      } else {
        card.style.display = "none";
        card.classList.remove("is-open");
        card.querySelector(".county-toggle")?.setAttribute("aria-expanded", "false");
      }
    });
  });
</script>
