---
import MainLayout from "../../layouts/MainLayout.astro";
---

<MainLayout
  title="Florida Tree Care Tools"
  description="Free Florida tree care tools for homeowners comparing storm risk, problem trees, permit questions, and tree service options."
>
  <section class="tools-hero">
    <div>
      <p>Florida homeowner resources</p>
      <h1>Florida Tree Care Tools</h1>
      <span>
        Use these simple guides before requesting a quote, comparing tree service
        options, or deciding whether a tree issue needs monitoring, documentation,
        or urgent local help.
      </span>
    </div>
  </section>

  <section class="tools-grid-section">
    <div class="tools-grid">
      <a class="tool-card primary" href="/tools/florida-tree-care-advisor/">
        <p>Decision helper</p>
        <h2>Florida Tree Care Advisor</h2>
        <span>Get Florida-specific guidance based on your area, season, and property concern.</span>
        <strong>Open advisor →</strong>
      </a>

      <a class="tool-card" href="/tools/florida-problem-tree-guide/">
        <p>Problem trees</p>
        <h2>Florida Problem Tree Guide</h2>
        <span>Check common invasive, storm-prone, messy, or hardscape-conflict trees.</span>
        <strong>Open guide →</strong>
      </a>
    </div>
  </section>
</MainLayout>

<style>
  .tools-hero {
    background: radial-gradient(circle at center, #164b34 0%, #082d20 72%);
    color: #fff;
    text-align: center;
    padding: clamp(5rem, 10vw, 8rem) 1.5rem;
    border-bottom: 6px solid #f25a06;
  }

  .tools-hero > div {
    max-width: 900px;
    margin: 0 auto;
  }

  .tools-hero p {
    margin: 0 0 1rem;
    color: #ffb703;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 0.15em;
  }

  .tools-hero h1 {
    margin: 0;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 0.95;
    letter-spacing: -0.06em;
  }

  .tools-hero span {
    display: block;
    max-width: 780px;
    margin: 1.5rem auto 0;
    color: #bbf7d0;
    font-size: clamp(1.05rem, 2vw, 1.35rem);
    line-height: 1.65;
  }

  .tools-grid-section {
    background: #f8faf9;
    padding: 5rem 1.5rem 8rem;
  }

  .tools-grid {
    max-width: 1120px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .tool-card {
    display: block;
    background: #fff;
    border: 1px solid #dbe4df;
    border-radius: 2rem;
    padding: clamp(2rem, 4vw, 3rem);
    text-decoration: none;
    color: #475569;
    box-shadow: 0 18px 50px rgba(15, 63, 42, 0.08);
    min-height: 320px;
  }

  .tool-card.primary {
    background: #082d20;
    color: #d1fae5;
  }

  .tool-card p {
    margin: 0 0 0.8rem;
    color: #f25a06;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    font-size: 0.8rem;
    font-weight: 900;
  }

  .tool-card.primary p { color: #ffb703; }

  .tool-card h2 {
    color: #0f3f2a;
    margin: 0 0 1rem;
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1;
    letter-spacing: -0.05em;
  }

  .tool-card.primary h2 { color: #fff; }

  .tool-card span {
    display: block;
    line-height: 1.8;
    font-size: 1.05rem;
    margin-bottom: 2rem;
  }

  .tool-card strong {
    color: #f25a06;
    font-weight: 900;
  }

  @media (max-width: 800px) {
    .tools-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
