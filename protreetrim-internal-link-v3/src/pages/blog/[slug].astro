---
import MainLayout from "../../layouts/MainLayout.astro";
import { SITE_CONFIG } from "../../config.js";
import { getCollection } from "astro:content";
import { getBlogMoneyLinks } from "../../data/internal-links.js";

const slugifyCategory = (value) =>
  value
    .toLowerCase()
    .trim()
    .replace(/&/g, "and")
    .replace(/[^a-z0-9\s-]/g, "")
    .replace(/\s+/g, "-");

export async function getStaticPaths() {
  const posts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));

  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await post.render();

const allPosts = await getCollection("blog", ({ data, slug }) => !data.draft && !/\s\(\d+\)$/.test(slug));
const relatedPosts = allPosts
  .filter(
    (item) =>
      item.slug !== post.slug && item.data.category === post.data.category
  )
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const canonicalUrl = `${SITE_CONFIG.siteUrl}/blog/${post.slug}/`;
const categoryUrl = `/blog/category/${slugifyCategory(post.data.category)}/`;
const moneyPageLinks = getBlogMoneyLinks({
  slug: post.slug,
  title: post.data.title,
  category: post.data.category,
  tags: post.data.tags || [],
});
---

<MainLayout
  title={post.data.title}
  description={post.data.description}
  canonical={canonicalUrl}
  ogType="article"
>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify({
        "@context": "https://schema.org",
        "@type": "BlogPosting",
        headline: post.data.title,
        description: post.data.description,
        datePublished: post.data.pubDate,
        dateModified: post.data.updatedDate ?? post.data.pubDate,
        author: {
          "@type": "Person",
          name: post.data.author,
        },
        publisher: {
          "@type": "Organization",
          name: "ProTreeTrim",
        },
        mainEntityOfPage: canonicalUrl,
      })}
    />
  </Fragment>

  <main class="container" style="max-width: 860px; padding: 4rem 1.5rem 10rem;">
    <a
      href="/blog/"
      style="display: inline-block; margin-bottom: 1.5rem; color: #166534; text-decoration: none; font-weight: 800;"
    >
      ← Back to blog
    </a>

    <article
      style="background: white; border: 1px solid #e5e7eb; border-radius: 28px; padding: 2rem 2rem 3rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
    >
      <div
        style="display: flex; gap: 10px; align-items: center; flex-wrap: wrap; margin-bottom: 1rem;"
      >
        <a
          href={categoryUrl}
          style="background: #f0fdf4; color: #166534; padding: 6px 12px; border-radius: 999px; font-size: 0.75rem; font-weight: 800; text-transform: uppercase; text-decoration: none;"
        >
          {post.data.category}
        </a>
        <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
          Published{" "}
          {post.data.pubDate.toLocaleDateString("en-US", {
            year: "numeric",
            month: "long",
            day: "numeric",
          })}
        </span>
        {
          post.data.updatedDate && (
            <span style="color: #94a3b8; font-size: 0.85rem; font-weight: 700;">
              Updated{" "}
              {post.data.updatedDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })}
            </span>
          )
        }
      </div>

      <h1
        style="font-size: clamp(2rem, 5vw, 3.3rem); line-height: 1.08; color: #1b4332; margin: 0 0 1rem; font-weight: 900;"
      >
        {post.data.title}
      </h1>

      <p style="font-size: 1.1rem; line-height: 1.75; color: #475569; margin-bottom: 2rem;">
        {post.data.description}
      </p>

      <div class="blog-prose">
        <Content />
      </div>
    </article>

    {
      moneyPageLinks.length > 0 && (
        <section style="margin-top: 2rem;">
          <div
            style="background: #f0fdf4; border: 1px solid #dcfce7; border-radius: 28px; padding: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
          >
            <div style="margin-bottom: 1.2rem;">
              <span
                style="display: inline-block; background: white; color: #166534; border: 1px solid #bbf7d0; padding: 5px 12px; border-radius: 999px; font-size: 0.72rem; font-weight: 900; text-transform: uppercase;"
              >
                Local service pages
              </span>
              <h2 style="margin: 0.8rem 0 0.4rem; color: #1b4332; font-size: 1.5rem;">
                Related Florida service areas
              </h2>
              <p style="margin: 0; color: #4b5563; line-height: 1.7;">
                Use these local pages to compare service availability, estimate factors, and planning notes for high-intent Florida tree work.
              </p>
            </div>

            <div
              style="display: grid; grid-template-columns: repeat(auto-fit, minmax(230px, 1fr)); gap: 14px;"
            >
              {moneyPageLinks.map((link) => (
                <a
                  href={link.href}
                  style="display: block; background: white; border: 1px solid #dcfce7; border-radius: 18px; padding: 1rem; text-decoration: none; color: inherit;"
                >
                  <div style="color: #16a34a; font-size: 0.72rem; font-weight: 900; text-transform: uppercase; margin-bottom: 0.45rem;">
                    {link.eyebrow}
                  </div>
                  <strong style="display: block; color: #1b4332; font-size: 1rem; line-height: 1.35;">
                    {link.title}
                  </strong>
                  <span style="display: block; color: #64748b; font-size: 0.85rem; line-height: 1.5; margin-top: 0.45rem;">
                    {link.reason}
                  </span>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }

    {
      relatedPosts.length > 0 && (
        <section style="margin-top: 2rem;">
          <div
            style="background: white; border: 1px solid #e5e7eb; border-radius: 28px; padding: 2rem; box-shadow: 0 10px 30px rgba(0,0,0,0.03);"
          >
            <div
              style="display: flex; align-items: center; justify-content: space-between; gap: 15px; flex-wrap: wrap; margin-bottom: 1rem;"
            >
              <h2 style="margin: 0; color: #1b4332; font-size: 1.5rem;">
                More in {post.data.category}
              </h2>
              <a
                href={categoryUrl}
                style="color: #ea580c; text-decoration: none; font-weight: 800;"
              >
                View category →
              </a>
            </div>

            <div
              style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 16px;"
            >
              {relatedPosts.map((item) => (
                <a
                  href={`/blog/${item.slug}/`}
                  style="display: block; text-decoration: none; color: inherit; border: 1px solid #e5e7eb; border-radius: 18px; padding: 1rem;"
                >
                  <div style="color: #94a3b8; font-size: 0.8rem; font-weight: 700; margin-bottom: 0.5rem;">
                    {item.data.pubDate.toLocaleDateString("en-US", {
                      year: "numeric",
                      month: "long",
                      day: "numeric",
                    })}
                  </div>
                  <div style="color: #1b4332; font-weight: 900; line-height: 1.3;">
                    {item.data.title}
                  </div>
                </a>
              ))}
            </div>
          </div>
        </section>
      )
    }
  </main>
</MainLayout>

<style>
  .blog-prose {
    color: #374151;
    font-size: 1.05rem;
    line-height: 1.9;
  }

  .blog-prose h2,
  .blog-prose h3 {
    color: #1b4332;
    line-height: 1.2;
    margin-top: 2.2rem;
    margin-bottom: 0.9rem;
    font-weight: 900;
  }

  .blog-prose h2 {
    font-size: 1.8rem;
  }

  .blog-prose h3 {
    font-size: 1.35rem;
  }

  .blog-prose p,
  .blog-prose ul,
  .blog-prose ol {
    margin: 0 0 1.1rem;
  }

  .blog-prose ul,
  .blog-prose ol {
    padding-left: 1.4rem;
  }

  .blog-prose a {
    color: #ea580c;
    font-weight: 700;
  }

  .blog-prose strong {
    color: #111827;
  }

  .blog-prose blockquote {
    margin: 1.5rem 0;
    padding: 1rem 1.25rem;
    border-left: 4px solid #ea580c;
    background: #fff7ed;
    border-radius: 12px;
  }
</style>